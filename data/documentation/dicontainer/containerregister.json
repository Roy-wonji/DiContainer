{"hierarchy":{"paths":[["doc:\/\/DiContainer\/documentation\/DiContainer"]]},"metadata":{"role":"symbol","symbolKind":"struct","externalID":"s:11DiContainer0B8RegisterV","roleHeading":"Structure","modules":[{"name":"DiContainer"}],"navigatorTitle":[{"text":"ContainerRegister","kind":"identifier"}],"title":"ContainerRegister","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ContainerRegister","kind":"identifier"}]},"topicSections":[{"identifiers":["doc:\/\/DiContainer\/documentation\/DiContainer\/ContainerRegister\/init(_:)","doc:\/\/DiContainer\/documentation\/DiContainer\/ContainerRegister\/init(_:defaultFactory:)"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"identifiers":["doc:\/\/DiContainer\/documentation\/DiContainer\/ContainerRegister\/wrappedValue"],"generated":true,"anchor":"Instance-Properties","title":"Instance Properties"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/dicontainer\/containerregister"]}],"kind":"symbol","abstract":[{"text":"전역 ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/DependencyContainer"},{"text":"에서 의존성을 주입하는 프로퍼티 래퍼입니다.","type":"text"}],"identifier":{"url":"doc:\/\/DiContainer\/documentation\/DiContainer\/ContainerRegister","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@propertyWrapper","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ContainerRegister","kind":"identifier"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Sendable","preciseIdentifier":"s:s8SendableP","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"ContainerRegister"},{"type":"text","text":"는 전역 의존성 컨테이너에서 KeyPath 기반의 의존성 주입을"},{"type":"text","text":" "},{"type":"text","text":"선언적으로 수행할 수 있도록 하는 프로퍼티 래퍼입니다. 타입 안전성을 보장하며,"},{"type":"text","text":" "},{"type":"text","text":"기본 팩토리가 제공된 경우 자동 등록 기능을 제공합니다."}],"type":"paragraph"},{"text":"개요","anchor":"%EA%B0%9C%EC%9A%94","level":2,"type":"heading"},{"inlineContent":[{"text":"이 프로퍼티 래퍼는 전역 컨테이너(","type":"text"},{"code":"DependencyContainer.live","type":"codeVoice"},{"text":")에서 KeyPath를","type":"text"},{"text":" ","type":"text"},{"text":"기반으로 의존성을 해결합니다. 의존성이 등록되지 않았고 기본 팩토리가 제공되지","type":"text"},{"text":" ","type":"text"},{"text":"않은 경우, 의존성 구성 문제를 조기에 발견할 수 있도록 애플리케이션을 즉시 종료합니다.","type":"text"}],"type":"paragraph"},{"text":"스레드 안전성","anchor":"%EC%8A%A4%EB%A0%88%EB%93%9C-%EC%95%88%EC%A0%84%EC%84%B1","level":3,"type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"DependencyContainer"},{"type":"text","text":"가 스레드 안전하게 설계되었으므로, "},{"type":"codeVoice","code":"ContainerRegister"},{"type":"text","text":"는"},{"type":"text","text":" "},{"type":"text","text":"동시성 컨텍스트에서 안전하게 접근할 수 있습니다. 다만, 의존성들은 동시 접근이"},{"type":"text","text":" "},{"type":"text","text":"발생하기 전인 애플리케이션 초기화 시점에 등록되어야 합니다."}],"type":"paragraph"},{"text":"자동 등록","anchor":"%EC%9E%90%EB%8F%99-%EB%93%B1%EB%A1%9D","level":3,"type":"heading"},{"inlineContent":[{"code":"defaultFactory","type":"codeVoice"},{"text":"와 함께 초기화될 때, ","type":"text"},{"code":"ContainerRegister","type":"codeVoice"},{"text":"는 누락된 의존성을","type":"text"},{"text":" ","type":"text"},{"text":"자동으로 등록할 수 있어서 옵셔널하거나 모킹된 의존성에 대한 폴백 메커니즘을","type":"text"},{"text":" ","type":"text"},{"text":"제공합니다.","type":"text"}],"type":"paragraph"},{"text":"사용법","anchor":"%EC%82%AC%EC%9A%A9%EB%B2%95","level":2,"type":"heading"},{"text":"기본 의존성 주입","anchor":"%EA%B8%B0%EB%B3%B8-%EC%9D%98%EC%A1%B4%EC%84%B1-%EC%A3%BC%EC%9E%85","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"먼저 "},{"code":"DependencyContainer","type":"codeVoice"},{"type":"text","text":"를 확장하여 의존성에 대한 계산 프로퍼티를 제공합니다:"}],"type":"paragraph"},{"syntax":"swift","code":["extension DependencyContainer {","    var networkService: NetworkServiceProtocol? {","        resolve(NetworkServiceProtocol.self)","    }","","    var authRepository: AuthRepositoryProtocol? {","        resolve(AuthRepositoryProtocol.self)","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"앱 초기화 중에 의존성을 등록합니다:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ 앱의 부트스트랩\/설정 단계에서","DependencyContainer.live.register(NetworkServiceProtocol.self) {","    DefaultNetworkService()","}","","DependencyContainer.live.register(AuthRepositoryProtocol.self) {","    DefaultAuthRepository()","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"마지막으로 타입에서 의존성을 주입합니다:"}],"type":"paragraph"},{"syntax":"swift","code":["final class APIClient {","    @ContainerRegister(\\.networkService)","    private var networkService: NetworkServiceProtocol","","    @ContainerRegister(\\.authRepository)","    private var authRepository: AuthRepositoryProtocol","","    func performAuthenticatedRequest() async throws -> Data {","        let token = try await authRepository.getAccessToken()","        return try await networkService.request(\"\/api\/data\", headers: [\"Authorization\": \"Bearer \\(token)\"])","    }","}"],"type":"codeListing"},{"text":"기본 팩토리를 이용한 자동 등록","anchor":"%EA%B8%B0%EB%B3%B8-%ED%8C%A9%ED%86%A0%EB%A6%AC%EB%A5%BC-%EC%9D%B4%EC%9A%A9%ED%95%9C-%EC%9E%90%EB%8F%99-%EB%93%B1%EB%A1%9D","level":3,"type":"heading"},{"inlineContent":[{"text":"테스트나 개발 환경에서는 기본 구현체를 제공할 수 있습니다:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["final class TestableService {","    @ContainerRegister(\\.networkService, defaultFactory: { MockNetworkService() })","    private var networkService: NetworkServiceProtocol","","    \/\/ 실제 구현체가 등록되지 않은 경우 MockNetworkService를 사용합니다","}"],"type":"codeListing"},{"text":"주제","anchor":"%EC%A3%BC%EC%A0%9C","level":2,"type":"heading"},{"text":"초기화자","anchor":"%EC%B4%88%EA%B8%B0%ED%99%94%EC%9E%90","level":3,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/ContainerRegister\/init(_:)","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/ContainerRegister\/init(_:defaultFactory:)","isActive":true}]}]}],"type":"unorderedList"},{"text":"프로퍼티","anchor":"%ED%94%84%EB%A1%9C%ED%8D%BC%ED%8B%B0","level":3,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/ContainerRegister\/wrappedValue"}]}]}],"type":"unorderedList"}],"kind":"content"}],"references":{"doc://DiContainer/documentation/DiContainer":{"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer","url":"\/documentation\/dicontainer","title":"DiContainer","type":"topic","kind":"symbol","abstract":[],"role":"collection"},"doc://DiContainer/documentation/DiContainer/ContainerRegister/init(_:defaultFactory:)":{"type":"topic","url":"\/documentation\/dicontainer\/containerregister\/init(_:defaultfactory:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"KeyPath","preciseIdentifier":"s:s7KeyPathC","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"DependencyContainer","preciseIdentifier":"s:11DiContainer010DependencyB0C","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":"?>, ","kind":"text"},{"text":"defaultFactory","kind":"externalParam"},{"text":": () -> ","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":")","kind":"text"}],"identifier":"doc:\/