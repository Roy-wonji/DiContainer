":"heading"},{"syntax":"swift","code":["protocol AuthRepositoryProtocol {","    func login(user: String, password: String) async -> Bool","}","","struct DefaultAuthRepository: AuthRepositoryProtocol {","    func login(user: String, password: String) async -> Bool {","        \/\/ 실제 로그인 로직 구현","        return true","    }","}"],"type":"codeListing"},{"text":"2) 기본 의존성 등록","anchor":"2-%EA%B8%B0%EB%B3%B8-%EC%9D%98%EC%A1%B4%EC%84%B1-%EB%93%B1%EB%A1%9D","level":3,"type":"heading"},{"syntax":"swift","code":["extension RepositoryModuleFactory {","    public mutating func registerDefaultDefinitions() {","        let helper = registerModule","        repositoryDefinitions = [","            helper.makeDependency(AuthRepositoryProtocol.self) {","                DefaultAuthRepository()","            }","        ]","    }","}"],"type":"codeListing"},{"text":"3) DI 컨테이너에 등록","anchor":"3-DI-%EC%BB%A8%ED%85%8C%EC%9D%B4%EB%84%88%EC%97%90-%EB%93%B1%EB%A1%9D","level":3,"type":"heading"},{"syntax":"swift","code":["extension AppDIContainer {","    public func registerAuthRepository() async {","        var factoryCopy = RepositoryModuleFactory()","        factoryCopy.registerDefaultDefinitions()","","        await registerDependencies { container in","            for module in factoryCopy.makeAllModules() {","                await container.register(module)","            }","        }","    }","}"],"type":"codeListing"},{"text":"4) 앱 초기화 시점에서 호출","anchor":"4-%EC%95%B1-%EC%B4%88%EA%B8%B0%ED%99%94-%EC%8B%9C%EC%A0%90%EC%97%90%EC%84%9C-%ED%98%B8%EC%B6%9C","level":3,"type":"heading"},{"text":"SwiftUI","anchor":"SwiftUI","level":4,"type":"heading"},{"syntax":"swift","code":["@main","struct MyApp: App {","    init() {","        Task {","            await AppDIContainer.shared.registerAuthRepository()","        }","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","}"],"type":"codeListing"},{"text":"UIKit","anchor":"UIKit","level":4,"