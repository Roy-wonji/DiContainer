{"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"UnifiedDI","text":"UnifiedDI"},{"level":3,"type":"heading","anchor":"%EB%93%B1%EB%A1%9DRegistration","text":"등록(Registration)"},{"code":["\/\/ 기본 등록","UnifiedDI.register(Service.self) { ServiceImpl() }","","\/\/ 조건부 등록","UnifiedDI.registerIf(Analytics.self,","                     condition: isProd,","                     factory: { FirebaseAnalytics() },","                     fallback: { NoOpAnalytics() })","","\/\/ 스코프 등록 (동기)","UnifiedDI.registerScoped(UserService.self, scope: .session) { UserServiceImpl() }","","\/\/ 스코프 등록 (비동기)","UnifiedDI.registerAsyncScoped(ProfileCache.self, scope: .screen) {","    await ProfileCache.make()","}"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"%ED%95%B4%EA%B2%B0Resolution","text":"해결(Resolution)"},{"code":["\/\/ 옵셔널 해결","let s1: Service? = UnifiedDI.resolve(Service.self)","","\/\/ 필수 해결 (미등록 시 fatalError)","let s2: Service = UnifiedDI.requireResolve(Service.self)","","\/\/ throws 기반 해결","let s3: Service = try UnifiedDI.resolveThrows(Service.self)","","\/\/ 기본값과 함께 해결","let s4: Service = UnifiedDI.resolve(Service.self, default: MockService())","","\/\/ 비동기 해결","let s5: Service? = await UnifiedDI.resolveAsync(Service.self)"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"%ED%95%B4%EC%A0%9CRelease","text":"해제(Release)"},{"code":["\/\/ 타입 해제","UnifiedDI.release(Service.self)","","\/\/ 전체 해제 (테스트\/디버그 용도)","await UnifiedDI.releaseAll()","","\/\/ 스코프 전체 해제","UnifiedDI.releaseScope(.session, id: userID)","","\/\/ 특정 타입의 스코프 인스턴스 해제","UnifiedDI.releaseScoped(UserService.self, kind: .session, id: userID)"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"%ED%8C%81Tips","text":"팁(Tips)"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"스코프: ","type":"text"},{"code":".screen","type":"codeVoice"},{"text":", ","type":"text"},{"code":".session","type":"codeVoice"},{"text":", ","type":"text"},{"code":".request","type":"codeVoice"},{"text":" 제공. 수명주기에 맞춰 ","type":"text"},{"code":"ScopeContext.shared.setCurrent\/clear","type":"codeVoice"},{"text":"를 사용하세요.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"비동기 싱글톤: ","type":"text"},{"code":"GlobalUnifiedRegistry.registerAsyncSingleton(Type.self) { await ... }","type":"codeVoice"},{"text":" 패턴으로 최초 1회 생성 후 재사용합니다.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"그래프 자동 수집(선택): "},{"code":"CircularDependencyDetector.shared.setAutoRecordingEnabled(true)","type":"codeVoice"},{"type":"text","text":" 설정 시, 해석 경로에서 자동으로 의존 엣지를 기록합니다."}],"type":"paragraph"}]}]},{"type":"thematicBreak"},{"level":2,"type":"heading","anchor":"DI-%EB%8B%A8%EC%88%9C%ED%99%94-API","text":"DI (단순화 API)"},{"type":"heading","anchor":"%EB%93%B1%EB%A1%9DRegistration","text":"등록(Registration)","level":3},{"type":"codeListing","syntax":"swift","code":["\/\/ 기본 등록","DI.register(Service.self) { ServiceImpl() }","","\/\/ 조건부 등록","DI.registerIf(Service.self, condition: flag,","              factory: { RealService() },","              fallback: { MockService() })","","\/\/ 스코프 등록 (동기\/비동기)","DI.registerScoped(UserService.self, scope: .request) { UserServiceImpl() }","DI.registerAsyncScoped(RequestContext.self, scope: .request) { await RequestContext.create() }"]},{"type":"heading","anchor":"%ED%95%B4%EA%B2%B0Resolution","text":"해결(Resolution)","level":3},{"type":"codeListing","syntax":"swift","code":["let d1: Service? = DI.resolve(Service.self)","let d2: Result<Service, DIError> = DI.resolveResult(Service.self)","let d3: Service = try DI.resolveThrows(Service.self)"]},{"type":"heading","anchor":"%ED%95%B4%EC%A0%9CRelease","text":"해제(Release)","level":3},{"type":"codeListing","syntax":"swift","code":["DI.release(Service.self)","DI.releaseScope(.request, id: requestID)","DI.releaseScoped(UserService.self, kind: .request, id: requestID)"]},{"ty