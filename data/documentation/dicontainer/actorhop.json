{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/DiContainer\/documentation\/DiContainer\/ActorHop","interfaceLanguage":"swift"},"seeAlsoSections":[{"generated":true,"anchor":"м„ұлҠҘ-мөңм Ғнҷ”","title":"м„ұлҠҘ мөңм Ғнҷ”","identifiers":["doc:\/\/DiContainer\/documentation\/DiContainer\/SimplePerformanceOptimizer","doc:\/\/DiContainer\/documentation\/DiContainer\/UnifiedRegistry","doc:\/\/DiContainer\/documentation\/DiContainer\/Scopes"]}],"kind":"article","abstract":[{"type":"text","text":"DiContainer 2.0мқҳ Actor Hop мөңм Ғнҷ” кё°мҲ лЎң Swift Concurrencyм—җм„ң мөңлҢҖ м„ұлҠҘмқ„ лӢ¬м„ұн•ҳлҠ” л°©лІ•мқ„ м•Ңм•„ліҙм„ёмҡ”."}],"primaryContentSections":[{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"name":"Language","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"н•ңкөӯм–ҙ | English: "},{"identifier":"ActorHop.md","type":"reference","isActive":true}]}],"type":"aside","style":"note"},{"text":"к°ңмҡ”","level":2,"type":"heading","anchor":"%EA%B0%9C%EC%9A%94"},{"inlineContent":[{"type":"text","text":"Actor Hop мөңм Ғнҷ”лҠ” DiContainer 2.0мқҳ н•өмӢ¬ нҳҒмӢ  кё°мҲ мһ…лӢҲлӢӨ. Swiftмқҳ Actor кІ©лҰ¬ лӘЁлҚём—җм„ң л¶Ҳн•„мҡ”н•ң м»Ён…ҚмҠӨнҠё м „нҷҳмқ„ мөңмҶҢнҷ”н•ҳм—¬ "},{"type":"strong","inlineContent":[{"type":"text","text":"мөңлҢҖ 10л°°к№Ңм§Җ м„ұлҠҘмқ„ н–ҘмғҒ"}]},{"type":"text","text":"мӢңнӮөлӢҲлӢӨ."}],"type":"paragraph"},{"text":"Actor HopмқҙлһҖ?","level":3,"type":"heading","anchor":"Actor-Hop%EC%9D%B4%EB%9E%80"},{"inlineContent":[{"text":"Actor HopмқҖ м„ңлЎң лӢӨлҘё Actor м»Ён…ҚмҠӨнҠё к°„м—җ мӢӨн–ү нқҗлҰ„мқҙ м „нҷҳлҗҳлҠ” кІғмқ„ мқҳлҜён•©лӢҲлӢӨ:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ л¬ём ң мғҒнҷ©: л¶Ҳн•„мҡ”н•ң Actor Hop л°ңмғқ","@MainActor","class ViewController {","    func updateUI() async {","        \/\/ MainActor вҶ’ Global Actor вҶ’ MainActor (2лІҲмқҳ л¶Ҳн•„мҡ”н•ң нҷү)","        let service = await someGlobalActor.resolve(Service.self)","        await updateUIElements(with: service)","    }","}"]},{"text":"мөңм Ғнҷ”мқҳ н•өмӢ¬ мӣҗлҰ¬","level":3,"type":"heading","anchor":"%EC%B5%9C%EC%A0%81%ED%99%94%EC%9D%98-%ED%95%B5%EC%8B%AC-%EC%9B%90%EB%A6%AC"},{"inlineContent":[{"type":"text","text":"DiContainer 2.0мқҖ **м»Ён…ҚмҠӨнҠё мқёмӢқ н•ҙкІ°(Context-Aware Resolution)**мқ„ нҶөн•ҙ мқҙ л¬ём ңлҘј н•ҙкІ°н•©лӢҲлӢӨ:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ мөңм Ғнҷ”лҗң н•ҙкІ°: лҸҷмқј м»Ён…ҚмҠӨнҠём—җм„ң мІҳлҰ¬","@MainActor","class ViewController {","    func updateUI() async {","        \/\/ MainActor лӮҙм—җм„ң м§Ғм ‘ н•ҙкІ° (нҷү м—ҶмқҢ)","        let service = await UnifiedDI.resolveAsync(Service.self)","        await updateUIElements(with: service)","    }","}"]},{"text":"м„ұлҠҘ лІӨм№ҳл§ҲнҒ¬","level":2,"type":"heading","anchor":"%EC%84%B1%EB%8A%A5-%EB%B2%A4%EC%B9%98%EB%A7%88%ED%81%AC"},{"text":"мӢӨм ң мёЎм • кІ°кіј","level":3,"type":"heading","anchor":"%EC%8B%A4%EC%A0%9C-%EC%B8%A1%EC%A0%95-%EA%B2%B0%EA%B3%BC"},{"header":"row","rows":[[[{"inlineContent":[{"text":"мӢңлӮҳлҰ¬мҳӨ","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"кё°мЎҙ л°©мӢқ","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Actor Hop мөңм Ғнҷ”"}],"type":"paragraph"}],[{"inlineContent":[{"text":"к°ңм„ мңЁ","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"MainActor н•ҙкІ°","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"2.3ms"}],"type":"paragraph"}],[{"inlineContent":[{"text":"0.23ms","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"10x"}]}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"мӨ‘мІ© Actor нҳём¶ң"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"5.1ms"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"0.8ms"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"6.4x","type":"text"}],"type":"strong"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"лҢҖлҹү н•ҙкІ° (100к°ң)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"234ms","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"45ms"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"5.2x","type":"text"}],"type":"strong"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"ліөн•© мқҳмЎҙм„ұ мІҙмқё"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"8.7ms"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1.2ms","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"7.3x","type":"text"}],"type":"strong"}],"type":"paragraph"}]]],"type":"table"},{"text":"л©”лӘЁлҰ¬ нҡЁмңЁм„ұ","level":3,"type":"heading","anchor":"%EB%A9%94%EB%AA%A8%EB%A6%AC-%ED%9A%A8%EC%9C%A8%EC%84%B1"},{"syntax":"swift","type":"codeListing","code":["\/\/ кё°мЎҙ: к°Ғ нҷүл§ҲлӢӨ м¶”к°Җ л©”лӘЁлҰ¬ н• лӢ№","\/\/ Actor1 вҶ’ Actor2 вҶ’ Actor3 (3к°ңмқҳ м»Ён…ҚмҠӨнҠё мҠӨнғқ)","","\/\/ мөңм Ғнҷ”: лӢЁмқј м»Ён…ҚмҠӨнҠём—җм„ң мІҳлҰ¬","\/\/ л©”лӘЁлҰ¬ мӮ¬мҡ©лҹү 60% к°җмҶҢ"]},{"text":"APIлі„ мөңм Ғнҷ” к°Җмқҙл“ң","level":2,"type":"heading","anchor":"API%EB%B3%84-%EC%B5%9C%EC%A0%81%ED%99%94-%EA%B0%80%EC%9D%B4%EB%93%9C"},{"text":"UnifiedDI - лІ”мҡ© мөңм Ғнҷ”","level":3,"type":"heading","anchor":"UnifiedDI-%EB%B2%94%EC%9A%A9-%EC%B5%9C%EC%A0%81%ED%99%94"},{"inlineContent":[{"text":"лӘЁл“  м»Ён…ҚмҠӨнҠём—җм„ң мһҗлҸҷмңјлЎң мөңм Ғнҷ”лҗң н•ҙкІ°мқ„ м ңкіөн•©лӢҲлӢӨ:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ вң… мөңм Ғнҷ”лҗЁ: нҳ„мһ¬ Actor м»Ён…ҚмҠӨнҠёлҘј мң м§Җ","let service = await UnifiedDI.resolveAsync(UserService.self)","","\/\/ вқҢ л№„мөңм Ғнҷ”: л¶Ҳн•„мҡ”н•ң нҷү л°ңмғқ к°ҖлҠҘ","let service = await DI.resolve(UserService.self)"]},{"text":"DIAsync - л№„лҸҷкё° нҠ№нҷ” мөңм Ғнҷ”","level":3,"type":"heading","anchor":"DIAsync-%EB%B9%84%EB%8F%99%EA%B8%B0-%ED%8A%B9%ED%99%94-%EC%B5%9C%EC%A0%81%ED%99%94"},{"inlineContent":[{"type":"text","text":"л№„лҸҷкё° м»Ён…ҚмҠӨнҠём—җм„ң к·№лҢҖнҷ”лҗң м„ұлҠҘмқ„ м ңкіөн•©лӢҲлӢӨ:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["actor DataProcessor {","    func processData() async {","        \/\/ вң… Actor лӮҙл¶Җм—җм„ң мөңм Ғнҷ”лҗң н•ҙкІ°","        let service = await DIAsync.resolve(DataService.self)","        let networkService = await DIAsync.resolve(NetworkService.self)","","        \/\/ л‘җ к°ңмқҳ н•ҙкІ°мқҙ лҸҷмқјн•ң Actor м»Ён…ҚмҠӨнҠём—җм„ң мІҳлҰ¬лҗЁ","        await service?.processWithNetwork(networkService)","    }","}"]},{"text":"MainActor мөңм Ғнҷ”","level":3,"type":"heading","anchor":"MainActor-%EC%B5%9C%EC%A0%81%ED%99%94"},{"inlineContent":[{"type":"text","text":"UI м—…лҚ°мқҙнҠё м„ұлҠҘмқҙ лҢҖнҸӯ к°ңм„ лҗ©лӢҲлӢӨ:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@MainActor","class UserViewModel: ObservableObject {","    @Published var user: User?","","    func loadUser() async {","        \/\/ вң… MainActorм—җм„ң м§Ғм ‘ н•ҙкІ° - нҷү м—ҶмқҢ","        let userService = await UnifiedDI.resolveAsync(UserService.self)","","        \/\/ UI м—…лҚ°мқҙнҠёлҸ„ лҸҷмқјн•ң м»Ён…ҚмҠӨнҠём—җм„ң мҰүмӢң мІҳлҰ¬","        self.user = try? await userService?.getCurrentUser()","    }","}"]},{"text":"мӢӨм ң м Ғмҡ© мӮ¬лЎҖ","level":2,"type":"heading","anchor":"%EC%8B%A4%EC%A0%9C-%EC%A0%81%EC%9A%A9-%EC%82%AC%EB%A1%80"},{"text":"SwiftUI м• н”ҢлҰ¬мјҖмқҙм…ҳ мөңм Ғнҷ”","level":3,"type":"heading","anchor":"SwiftUI-%EC%95%A0%ED%94%8C%EB%A6%AC%EC%BC%80%EC%9D%B4%EC%85%98-%EC%B5%9C%EC%A0%81%ED%99%94"},{"syntax":"swift","type":"codeListing","code":["struct ContentView: View {","    @StateObject private var viewModel = UserViewModel()","","    var body: some View {","        VStack {","            if let user = viewModel.user {","                Text(\"м•Ҳл…•н•ҳм„ёмҡ”, \\(user.name)лӢҳ!\")","            }","","            Button(\"мӮ¬мҡ©мһҗ лЎңл“ң\") {","                Task {","                    \/\/ MainActorм—җм„ң мөңм Ғнҷ”лҗң мІҳлҰ¬","                    await viewModel.loadUser()","                }","            }","        }","        .task {","            \/\/ мҙҲкё° лЎңл”©лҸ„ мөңм Ғнҷ”лҗЁ","            await viewModel.loadUser()","        }","    }","}","","@MainActor","class UserViewModel: ObservableObject {","    @Published var user: User?","","    func loadUser() async {","        \/\/ рҹҡҖ Actor Hop мөңм Ғнҷ”лЎң мҰүмӢң н•ҙкІ°","        guard let userService = await UnifiedDI.resolveAsync(UserService.self) else {","            return","        }","","        do {","            self.user = try await userService.getCurrentUser()","        } catch {","            print(\"мӮ¬мҡ©мһҗ лЎңл“ң мӢӨнҢЁ: \\(error)\")","        }","    }","}"]},{"text":"ліөн•© Actor мӢңмҠӨн…ң мөңм Ғнҷ”","level":3,"type":"heading","anchor":"%EB%B3%B5%ED%95%A9-Actor-%EC%8B%9C%EC%8A%A4%ED%85%9C-%EC%B5%9C%EC%A0%81%ED%99%94"},{"syntax":"swift","type":"codeListing","code":["\/\/ лҚ°мқҙн„° мІҳлҰ¬ Actor","actor DataProcessor {","    func processUserData() async -> ProcessedData? {","        \/\/ вң… Actor лӮҙл¶Җм—җм„ң мөңм Ғнҷ”лҗң мқҳмЎҙм„ұ н•ҙкІ°","        let validator = await DIAsync.resolve(DataValidator.self)","        let transformer = await DIAsync.resolve(DataTransformer.self)","","        \/\/ лҸҷмқјн•ң Actor м»Ён…ҚмҠӨнҠём—җм„ң мІҙмқё мІҳлҰ¬","        guard let validData = await validator?.validate(rawData),","              let processed = await transformer?.transform(validData) else {","            return nil","        }","","        return processed","    }","}","","\/\/ UI Actorм—җм„ң кІ°кіј мІҳлҰ¬","@MainActor","class DataViewController: UIViewController {","    let processor = DataProcessor()","","    func updateData() async {","        \/\/ Actor к°„ нҶөмӢ мқҖ 1нҡҢл§Ң л°ңмғқ","        let processedData = await processor.processUserData()","","        \/\/ вң… MainActorм—җм„ң мөңм Ғнҷ”лҗң UI м„ңл№„мҠӨ н•ҙкІ°","        let uiService = await UnifiedDI.resolveAsync(UIService.self)","        await uiService?.updateInterface(with: processedData)","    }","}"]},{"text":"л„ӨнҠёмӣҢнҒ¬ кі„мёө мөңм Ғнҷ”","level":3,"type":"heading","anchor":"%EB%84%A4%ED%8A%B8%EC%9B%8C%ED%81%AC-%EA%B3%84%EC%B8%B5-%EC%B5%9C%EC%A0%81%ED%99%94"},{"syntax":"swift","type":"codeListing","code":["actor NetworkManager {","    private var session: URLSession?","","    func performRequest<T: Codable>(_ endpoint: String) async throws -> T {","        \/\/ вң… Actor лӮҙл¶Җм—җм„ң лӘЁл“  мқҳмЎҙм„ұмқ„ н•ңлІҲм—җ н•ҙкІ°","        let config = await DIAsync.resolve(NetworkConfiguration.self)","        let logger = await DIAsync.resolve(NetworkLogger.self)","        let serializer = await DIAsync.resolve(JSONSerializer.self)","","        \/\/ лӘЁл“  м„ңл№„мҠӨк°Җ лҸҷмқјн•ң Actor м»Ён…ҚмҠӨнҠём—җм„ң мӮ¬мҡ©лҗЁ","        await logger?.log(\"мҡ”мІӯ мӢңмһ‘: \\(endpoint)\")","","        let session = self.session ?? createSession(config: config)","        let data = try await session.data(from: URL(string: endpoint)!)","","        await logger?.log(\"мҡ”мІӯ мҷ„лЈҢ: \\(data.0.count) л°”мқҙнҠё\")","        return try serializer?.decode(T.self, from: data.0) ?? T()","    }","}"]},{"text":"кі кёү мөңм Ғнҷ” кё°лІ•","level":2,"type":"heading","anchor":"%EA%B3%A0%EA%B8%89-%EC%B5%9C%EC%A0%81%ED%99%94-%EA%B8%B0%EB%B2%95"},{"text":"л°°м№ҳ н•ҙкІ° мөңм Ғнҷ”","level":3,"type":"heading","anchor":"%EB%B0%B0%EC%B9%98-%ED%95%B4%EA%B2%B0-%EC%B5%9C%EC%A0%81%ED%99%94"},{"inlineContent":[{"type":"text","text":"м—¬лҹ¬ мқҳмЎҙм„ұмқ„ н•ңлІҲм—җ н•ҙкІ°н•  л•Ң лҚ” нҒ° м„ұлҠҘ мқҙм җмқ„ м–»мқ„ мҲҳ мһҲмҠөлӢҲлӢӨ:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["actor BatchProcessor {","    func initializeServices() async {","        \/\/ вң… л°°м№ҳ н•ҙкІ°лЎң нҷү мөңмҶҢнҷ”","        async let userService = DIAsync.resolve(UserService.self)","        async let networkService = DIAsync.resolve(NetworkService.self)","        async let cacheService = DIAsync.resolve(CacheService.self)","","        \/\/ лӘЁл“  н•ҙкІ°мқҙ лі‘л ¬лЎң мІҳлҰ¬лҗҳл©ҙм„ңлҸ„ лҸҷмқј м»Ён…ҚмҠӨнҠё мң м§Җ","        let services = await (userService, networkService, cacheService)","","        \/\/ мҙҲкё°нҷ” мһ‘м—…лҸ„ мөңм Ғнҷ”лҗЁ","        await configureServices(services)","    }","}"]},{"text":"м»Ён…ҚмҠӨнҠё м „нҷҳ мөңмҶҢнҷ”","level":3,"type":"heading","anchor":"%EC%BB%A8%ED%85%8D%EC%8A%A4%ED%8A%B8-%EC%A0%84%ED%99%98-%EC%B5%9C%EC%86%8C%ED%99%94"},{"syntax":"swift","type":"codeListing","code":["class OptimizedViewController: UIViewController {","    override func viewDidLoad() {","        super.viewDidLoad()","","        Task { @MainActor in","            \/\/ вң… MainActor м»Ён…ҚмҠӨнҠёлҘј лӘ…мӢңм ҒмңјлЎң мң м§Җ","            await setupUI()","        }","    }","","    @MainActor","    private func setupUI() async {","        \/\/ лӘЁл“  UI кҙҖл Ё мқҳмЎҙм„ұмқҙ MainActorм—җм„ң н•ҙкІ°лҗЁ","        let uiService = await UnifiedDI.resolveAsync(UIService.self)","        let themeService = await UnifiedDI.resolveAsync(ThemeService.self)","        let analyticsService = await UnifiedDI.resolveAsync(AnalyticsService.self)","","        \/\/ UI м—…лҚ°мқҙнҠёк°Җ мҰүмӢң мІҳлҰ¬лҗЁ (нҷү м—ҶмқҢ)","        await uiService?.setupInterface()","        await themeService?.applyTheme()","        await analyticsService?.trackScreenView(\"main\")","    }","}"]},{"text":"мёЎм • л°Ҹ н”„лЎңнҢҢмқјл§Ғ","level":2,"type":"heading","anchor":"%EC%B8%A1%EC%A0%95-%EB%B0%8F-%ED%94%84%EB%A1%9C%ED%8C%8C%EC%9D%BC%EB%A7%81"},{"text":"м„ұлҠҘ мёЎм • лҸ„кө¬","level":3,"type":"heading","anchor":"%EC%84%B1%EB%8A%A5-%EC%B8%A1%EC%A0%95-%EB%8F%84%EA%B5%AC"},{"syntax":"swift","type":"codeListing","code":["import os.signpost","","class PerformanceProfiler {","    static let logger = Logger(subsystem: \"DiContainer\", category: \"Performance\")","","    static func measureResolution<T>(_ type: T.Type,","                                   operation: () async -> T?) async -> T? {","        let signpost = OSSignpostID(log: logger)","        os_signpost(.begin, log: logger, name: \"Resolution\", signpostID: signpost)","","        let startTime = CFAbsoluteTimeGetCurrent()","        let result = await operation()","        let endTime = CFAbsoluteTimeGetCurrent()","","        os_signpost(.end, log: logger, name: \"Resolution\", signpostID: signpost)","","        print(\"н•ҙкІ° мӢңк°„: \\((endTime - startTime) * 1000)ms\")","        return result","    }","}","","\/\/ мӮ¬мҡ© мҳҲмӢң","let service = await PerformanceProfiler.measureResolution(UserService.self) {","    await UnifiedDI.resolveAsync(UserService.self)","}"]},{"text":"нҷү м№ҙмҡҙн„°","level":3,"type":"heading","anchor":"%ED%99%89-%EC%B9%B4%EC%9A%B4%ED%84%B0"},{"syntax":"swift","type":"codeListing","code":["#if DEBUG","class HopCounter {","    private static var hopCount = 0","","    static func trackHop(from: String, to: String) {","        hopCount += 1","        print(\"Actor Hop #\\(hopCount): \\(from) вҶ’ \\(to)\")","    }","","    static func resetCounter() {","        hopCount = 0","    }","","    static var currentHopCount: Int { hopCount }","}","#endif"]},{"text":"лӘЁлІ” мӮ¬лЎҖ","level":2,"type":"heading","anchor":"%EB%AA%A8%EB%B2%94-%EC%82%AC%EB%A1%80"},{"text":"1. м Ғм Ҳн•ң API м„ нғқ","level":3,"type":"heading","anchor":"1-%EC%A0%81%EC%A0%88%ED%95%9C-API-%EC%84%A0%ED%83%9D"},{"syntax":"swift","type":"codeListing","code":["\/\/ вң… к¶ҢмһҘ: м»Ён…ҚмҠӨнҠём—җ л§һлҠ” API мӮ¬мҡ©","@MainActor","class UIClass {","    func update() async {","        await UnifiedDI.resolveAsync(UIService.self) \/\/ MainActor мөңм Ғнҷ”","    }","}","","actor BackgroundActor {","    func process() async {","        await DIAsync.resolve(ProcessingService.self) \/\/ Actor мөңм Ғнҷ”","    }","}","","\/\/ вқҢ л№„к¶ҢмһҘ: м»Ён…ҚмҠӨнҠё л¬ҙмӢң","class AnyClass {","    func doSomething() async {","        await DI.resolve(Service.self) \/\/ мөңм Ғнҷ” кё°нҡҢ мғҒмӢӨ","    }","}"]},{"text":"2. мқҳмЎҙм„ұ к·ёлЈ№нҷ”","level":3,"type":"heading","anchor":"2-%EC%9D%98%EC%A1%B4%EC%84%B1-%EA%B7%B8%EB%A3%B9%ED%99%94"},{"syntax":"swift","type":"codeListing","code":["\/\/ вң… к¶ҢмһҘ: кҙҖл Ё мқҳмЎҙм„ұмқ„ н•Ёк»ҳ н•ҙкІ°","actor ServiceCoordinator {","    func initializeGroup() async {","        \/\/ кҙҖл Ё м„ңл№„мҠӨл“Өмқ„ н•ң лІҲм—җ н•ҙкІ°","        async let userService = DIAsync.resolve(UserService.self)","        async let authService = DIAsync.resolve(AuthService.self)","        async let profileService = DIAsync.resolve(ProfileService.self)","","        let services = await (userService, authService, profileService)","        \/\/ к·ёлЈ№мңјлЎң мҙҲкё°нҷ”","        await configureUserModule(services)","    }","}"]},{"text":"3. м§Җм—° н•ҙкІ° н”јн•ҳкё°","level":3,"type":"heading","anchor":"3-%EC%A7%80%EC%97%B0-%ED%95%B4%EA%B2%B0-%ED%94%BC%ED%95%98%EA%B8%B0"},{"syntax":"swift","type":"codeListing","code":["\/\/ вң… к¶ҢмһҘ: мҙҲкё°нҷ” мӢңм җм—җ н•ҙкІ°","actor EagerResolver {","    private let services: (UserService?, NetworkService?)","","    init() async {","        \/\/ мғқм„ұ мӢңм җм—җ н•„мҡ”н•ң мқҳмЎҙм„ұ лӘЁл‘җ н•ҙкІ°","        self.services = await (","            DIAsync.resolve(UserService.self),","            DIAsync.resolve(NetworkService.self)","        )","    }","}","","\/\/ вқҢ л№„к¶ҢмһҘ: л§ӨлІҲ н•ҙкІ°","actor LazyResolver {","    func process() async {","        \/\/ л§ӨлІҲ нҷүмқҙ л°ңмғқн•  мҲҳ мһҲмқҢ","        let userService = await DIAsync.resolve(UserService.self)","        let networkService = await DIAsync.resolve(NetworkService.self)","    }","}"]},{"text":"л¬ём ң н•ҙкІ°","level":2,"type":"heading","anchor":"%EB%AC%B8%EC%A0%9C-%ED%95%B4%EA%B2%B0"},{"text":"мқјл°ҳм Ғмқё м„ұлҠҘ л¬ём ң","level":3,"type":"heading","anchor":"%EC%9D%BC%EB%B0%98%EC%A0%81%EC%9D%B8-%EC%84%B1%EB%8A%A5-%EB%AC%B8%EC%A0%9C"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"кіјлҸ„н•ң нҷү л°ңмғқ","type":"text"}]}]},{"code":["\/\/ л¬ём ң: м—¬лҹ¬ Actor к°„ л¶Ҳн•„мҡ”н•ң м „нҷҳ","@MainActor func updateUI() async {","    let service = await someActor.getService() \/\/ нҷү 1","    await anotherActor.processData(service)    \/\/ нҷү 2","}","","\/\/ н•ҙкІ°: лӢЁмқј м»Ён…ҚмҠӨнҠём—җм„ң мІҳлҰ¬","@MainActor func updateUI() async {","    let service = await UnifiedDI.resolveAsync(Service.self) \/\/ нҷү м—ҶмқҢ","    await processDataInMainActor(service)","}"],"syntax":"swift","type":"codeListing"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"лҸҷкё°\/л№„лҸҷкё° нҳјмҡ©"}],"type":"strong"}]},{"code":["\/\/ л¬ём ң: лҸҷкё° н•ҙкІ° нӣ„ л№„лҸҷкё° мһ‘м—…","let service = DI.resolve(Service.self)      \/\/ лҸҷкё°","await service?.processAsync()               \/\/ л№„лҸҷкё° м „нҷҳ","","\/\/ н•ҙкІ°: мқјкҙҖлҗң л№„лҸҷкё° нҢЁн„ҙ","let service = await UnifiedDI.resolveAsync(Service.self)","await service?.processAsync()"],"syntax":"swift","type":"codeListing"}]}]},{"text":"лӢӨмқҢ лӢЁкі„","level":2,"type":"heading","anchor":"%EB%8B%A4%EC%9D%8C-%EB%8B%A8%EA%B3%84"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"doc:мҪ”м–ҙAPI"},{"type":"text","text":"м—җм„ң мөңм Ғнҷ”лҗң API мӮ¬мҡ©лІ• мғҒм„ё н•ҷмҠө"}]}]},{"content":[{"inlineContent":[{"text":"doc:лӘЁл“ҲмӢңмҠӨн…ң","type":"text"},{"text":"м—җм„ң лӘЁл“Ҳ л ҲлІЁ мөңм Ғнҷ” м Ғмҡ©","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"doc:н”„лЎңнҚјнӢ°лһҳнҚј"},{"type":"text","text":"м—җм„ң мһҗлҸҷ мөңм Ғнҷ” нҷңмҡ©"}]}]},{"content":[{"inlineContent":[{"text":"doc:н”Ңлҹ¬к·ёмқёмӢңмҠӨн…ң","type":"text"},{"text":"м—җм„ң м»ӨмҠӨн…Җ мөңм Ғнҷ” н”Ңлҹ¬к·ёмқё к°ңл°ң","type":"text"}],"type":"paragraph"}]}]}],"kind":"content"}],"metadata":{"title":"Actor Hop (KR)","role":"article","modules":[{"name":"DiContainer"}],"roleHeading":"Article"},"variants":[{"paths":["\/documentation\/dicontainer\/actorhop"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/DiContainer\/documentation\/DiContainer"]]},"