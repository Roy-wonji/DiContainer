{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"DependencyContainer"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"개요","anchor":"%EA%B0%9C%EC%9A%94"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"DependencyContainer"},{"type":"text","text":"는 Swift 애플리케이션에서 의존성 주입(Dependency Injection)을"},{"type":"text","text":" "},{"type":"text","text":"관리하기 위한 스레드 안전한 컨테이너입니다. 이 컨테이너는 타입 기반의 의존성 등록과"},{"type":"text","text":" "},{"type":"text","text":"조회를 제공하며, Swift Concurrency와 완벽하게 호환됩니다."}]},{"level":2,"type":"heading","text":"핵심 특징","anchor":"%ED%95%B5%EC%8B%AC-%ED%8A%B9%EC%A7%95"},{"level":3,"type":"heading","text":"🔒 스레드 안전성","anchor":"%F0%9F%94%92-%EC%8A%A4%EB%A0%88%EB%93%9C-%EC%95%88%EC%A0%84%EC%84%B1"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"동시성 큐","type":"text"}]},{"type":"text","text":": "},{"type":"codeVoice","code":"DispatchQueue(attributes: .concurrent)"},{"type":"text","text":"를 사용하여 읽기 작업 최적화"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"배리어 플래그","type":"text"}],"type":"strong"},{"text":": 쓰기 작업 시 ","type":"text"},{"code":".barrier","type":"codeVoice"},{"text":" 플래그로 스레드 안전성 보장","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"다중 스레드 지원"}]},{"text":": 여러 스레드에서 동시에 안전하게 접근 가능","type":"text"}]}]}],"type":"unorderedList"},{"level":3,"type":"heading","text":"📝 타입 기반 등록 시스템","anchor":"%F0%9F%93%9D-%ED%83%80%EC%9E%85-%EA%B8%B0%EB%B0%98-%EB%93%B1%EB%A1%9D-%EC%8B%9C%EC%8A%A4%ED%85%9C"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"키 생성"}],"type":"strong"},{"text":": ","type":"text"},{"code":"String(describing: Type.self)","type":"codeVoice"},{"text":"를 통한 타입별 고유 키 생성","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"팩토리 패턴","type":"text"}]},{"text":": 지연 생성을 통한 메모리 효율성","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"인스턴스 등록"}],"type":"strong"},{"text":": 이미 생성된 객체의 직접 등록 지원","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"type":"heading","text":"🚀 생명 주기 관리","anchor":"%F0%9F%9A%80-%EC%83%9D%EB%AA%85-%EC%A3%BC%EA%B8%B0-%EA%B4%80%EB%A6%AC"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"부트스트랩"}],"type":"strong"},{"text":": 앱 시작 시 의존성 초기화","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"런타임 업데이트","type":"text"}]},{"type":"text","text":": 실행 중 의존성 교체 및 업데이트"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"정리"}],"type":"strong"},{"text":": 메모리 누수 방지를 위한 등록 해제 기능","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"기본 사용 방법","anchor":"%EA%B8%B0%EB%B3%B8-%EC%82%AC%EC%9A%A9-%EB%B0%A9%EB%B2%95"},{"level":3,"type":"heading","text":"1단계: 부트스트랩","anchor":"1%EB%8B%A8%EA%B3%84-%EB%B6%80%ED%8A%B8%EC%8A%A4%ED%8A%B8%EB%9E%A9"},{"type":"codeListing","code":["\/\/ SwiftUI 앱에서","@main","struct MyApp: App {","    init() {","        Task {","            await DependencyContainer.bootstrap { container in","                \/\/ 의존성 등록","                container.register(NetworkServiceProtocol.self) {","                    NetworkService(baseURL: URL(string: \"https:\/\/api.example.com\")!)","                }","                ","                container.register(UserRepositoryProtocol.self) {","                    UserRepository(networkService: container.resolve(NetworkServiceProtocol.self)!)","                }","            }","        }","    }","    ","    var body: some Scene {","        WindowGroup { ContentView() }","    }","}"],"syntax":"swift"},{"level":3,"type":"heading","text":"2단계: 의존성 등록","anchor":"2%EB%8B%A8%EA%B3%84-%EC%9D%98%EC%A1%B4%EC%84%B1-%EB%93%B1%EB%A1%9D"},{"type":"codeListing","code":["\/\/ 프로토콜 정의","protocol UserRepositoryProtocol {","    func fetchUser(id: String) async throws -> User","    func createUser(_ user: User) async throws -> User","}","","\/\/ 구현체 정의","struct UserRepository: UserRepositoryProtocol {","    private let networkService: NetworkServiceProtocol","    ","    init(networkService: NetworkServiceProtocol) {","        self.networkService = networkService","    }","    ","    func fetchUser(id: String) async throws -> User {","        return try await networkService.get(\"\/users\/\\(id)\")","    }","    ","    func createUser(_ user: User) async throws -> User {","        return try await networkService.post(\"\/users\", body: user)","    }","}","","\/\/ 팩토리 클로저로 등록","DependencyContainer.live.register(UserRepositoryProtocol.self) {","    UserRepository(networkService: \/* 다른 의존성 주입 *\/)","}"],"syntax":"swift"},{"level":3,"type":"heading","text":"3단계: 의존성 조회 및 사용","anchor":"3%EB%8B%A8%EA%B3%84-%EC%9D%98%EC%A1%B4%EC%84%B1-%EC%A1%B0%ED%9A%8C-%EB%B0%8F-%EC%82%AC%EC%9A%A9"},{"type":"codeListing","code":["class UserService {","    private let repository: UserRepositoryProtocol","    ","    init() {","        \/\/ 컨테이너에서 의존성 조회","        self.repository = DependencyContainer.live.resolve(UserRepositoryProtocol.self)!","    }","    ","    func getUser(id: String) async throws -> User {","        return try await repository.fetchUser(id: id)","    }","}","","\/\/ 또는 기본값과 함께 조회","let logger = DependencyContainer.live.resolveOrDefault(","    LoggerProtocol.self,","    default: ConsoleLogger()",")"],"syntax":"swift"},{"level":2,"type":"heading","text":"고급 사용 패턴","anchor":"%EA%B3%A0%EA%B8%89-%EC%82%AC%EC%9A%A9-%ED%8C%A8%ED%84%B4"},{"level":3,"type":"heading","text":"비동기 초기화가 필요한 의존성","anchor":"%EB%B9%84%EB%8F%99%EA%B8%B0-%EC%B4%88%EA%B8%B0%ED%99%94%EA%B0%80-%ED%95%84%EC%9A%94%ED%95%9C-%EC%9D%98%EC%A1%B4%EC%84%B1"},{"type":"codeListing","code":["await DependencyContainer.bootstrapAsync { container in","    \/\/ 동기 의존성 먼저 등록","    container.register(ConfigProtocol.self) { AppConfig() }","    ","    \/\/ 비동기 초기화가 필요한 의존성","    let database = await Database.initialize()","    container.register(Database.self, instance: database)","    ","    let remoteConfig = await RemoteConfigService.loadFromServer()","    container.register(RemoteConfigService.self, instance: remoteConfig)","}"],"syntax":"swift"},{"level":3,"type":"heading","text":"런타임 의존성 교체","anchor":"%EB%9F%B0%ED%83%80%EC%9E%84-%EC%9D%98%EC%A1%B4%EC%84%B1-%EA%B5%90%EC%B2%B4"},{"type":"codeListing","code":["\/\/ 개발 환경에서 프로덕션 환경으로 전환","await DependencyContainer.update { container in","    container.register(LoggerProtocol.self) { ","        ProductionLogger() \/\/ 기존 ConsoleLogger 교체","    }","    ","    container.register(AnalyticsProtocol.self) { ","        FirebaseAnalytics() \/\/ Mock에서 실제 구현체로 교체","    }","}"],"syntax":"swift"},{"level":3,"type":"heading","text":"메모리 관리 및 정리","anchor":"%EB%A9%94%EB%AA%A8%EB%A6%AC-%EA%B4%80%EB%A6%AC-%EB%B0%8F-%EC%A0%95%EB%A6%AC"},{"type":"codeListing","code":["\/\/ 등록 시 해제 핸들러 받기","let releaseHandler = DependencyContainer.live.register(TempServiceProtocol.self) {","    TemporaryService()","}","","\/\/ 필요 시 특정 의존성 해제","releaseHandler() \/\/ 직접 해제","","\/\/ 또는 타입으로 해제","DependencyContainer.live.release(TempServiceProtocol.self)"],"syntax":"swift"},{"level":2,"type":"heading","text":"에러 처리 및 디버깅","anchor":"%EC%97%90%EB%9F%AC-%EC%B2%98%EB%A6%AC-%EB%B0%8F-%EB%94%94%EB%B2%84%EA%B9%85"},{"level":3,"type":"heading","text":"등록되지 않은 의존성 처리","anchor":"%EB%93%B1%EB%A1%9D%EB%90%98%EC%A7%80-%EC%95%8A%EC%9D%80-%EC%9D%98%EC%A1%B4%EC%84%B1-%EC%B2%98%EB%A6%AC"},{"type":"codeListing","code":["\/\/ 안전한 조회 (옵셔널 반환)","if let service = DependencyContainer.live.resolve(OptionalServiceProtocol.self) {","    \/\/ 서비스가 등록된 경우에만 사용","    service.doSomething()","} else {","    print(\"OptionalServiceProtocol이 등록되지 않았습니다\")","}","","\/\/ 기본값과 함께 조회","let service = DependencyContainer.live.resolveOrDefault(","    ServiceProtocol.self,","    default: DefaultService() \/\/ 등록되지 않은 경우 기본 구현체 사용",")"],"syntax":"swift"},{"level":3,"type":"heading","text":"부트스트랩 상태 확인","anchor":"%EB%B6%80%ED%8A%B8%EC%8A%A4%ED%8A%B8%EB%9E%A9-%EC%83%81%ED%83%9C-%ED%99%95%EC%9D%B8"},{"type":"codeListing","code":["\/\/ 부트스트랩 완료 여부 확인","let isReady = await DependencyContainer.isBootstrapped","if !isReady {","    print(\"⚠️ 의존성 컨테이너가 아직 초기화되지 않았습니다\")","}","","\/\/ 부트스트랩 보장 (개발 중 유용)","await DependencyContainer.ensureBootstrapped()","\/\/ 부트스트랩되지 않은 경우 precondition failure로 크래시"],"syntax":"swift"},{"level":2,"type":"heading","text":"테스트 지원","anchor":"%ED%85%8C%EC%8A%A4%ED%8A%B8-%EC%A7%80%EC%9B%90"},{"level":3,"type":"heading","text":"테스트 환경 설정","anchor":"%ED%85%8C%EC%8A%A4%ED%8A%B8-%ED%99%98%EA%B2%BD-%EC%84%A4%EC%A0%95"},{"type":"codeListing","code":["class MyServiceTests: XCTestCase {","    ","    override func setUp() async throws {","        await super.setUp()","        ","        \/\/ 테스트용 컨테이너 리셋","        await DependencyContainer.resetForTesting()","        ","        \/\/ 테스트용 Mock 객체 등록","        await DependencyContainer.bootstrap { container in","            container.register(NetworkServiceProtocol.self) {","                MockNetworkService()","            }","            ","            container.register(UserRepositoryProtocol.self) {","                MockUserRepository(shouldFail: false)","            }","        }","    }","    ","    func testUserServiceSuccess() async throws {","        let service = UserService() \/\/ Mock 객체들이 자동 주입됨","        let user = try await service.getUser(id: \"123\")","        XCTAssertEqual(user.id, \"123\")","    }","    ","    func testUserServiceFailure() async throws {","        \/\/ 특정 테스트를 위한 설정 변경","        await DependencyContainer.update { container in","            container.register(UserRepositoryProtocol.self) {","                MockUserRepository(shouldFail: true)","            }","        }","        ","        let service = UserService()","        ","        do {","            _ = try await service.getUser(id: \"123\")","            XCTFail(\"예외가 발생해야 합니다\")","        } catch {","            XCTAssertTrue(error is UserServiceError)","        }","    }","}"],"syntax":"swift"},{"level":2,"type":"heading","text":"성능 고려사항","anchor":"%EC%84%B1%EB%8A%A5-%EA%B3%A0%EB%A0%A4%EC%82%AC%ED%95%AD"},{"level":3,"type":"heading","text":"메모리 효율성","anchor":"%EB%A9%94%EB%AA%A8%EB%A6%AC-%ED%9A%A8%EC%9C%A8%EC%84%B1"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"팩토리 패턴"}]},{"type":"text","text":": 의존성은 실제 필요할 때만 생성됩니다"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"약한 참조"}]},{"type":"text","text":": 순환 참조를 방지하기 위해 적절한 곳에서 "},{"code":"weak","type":"codeVoice"},{"type":"text","text":" 사용"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"인스턴스 등록"}]},{"text":": 싱글톤 객체는 ","type":"text"},{"type":"codeVoice","code":"register(_:instance:)"},{"text":"로 직접 등록","type":"text"}]}]}],"type":"unorderedList"},{"level":3,"type":"heading","text":"동시성 최적화","anchor":"%EB%8F%99%EC%8B%9C%EC%84%B1-%EC%B5%9C%EC%A0%81%ED%99%94"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"읽기 최적화","type":"text"}],"type":"strong"},{"type":"text","text":": 여러 스레드에서 동시 읽기 가능"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"쓰기 직렬화"}],"type":"strong"},{"text":": 배리어 플래그로 쓰기 작업 동기화","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"부트스트랩 코디네이터"}],"type":"strong"},{"text":": Actor를 통한 초기화 과정 관리","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"주의사항 및 제한사항","anchor":"%EC%A3%BC%EC%9D%98%EC%82%AC%ED%95%AD-%EB%B0%8F-%EC%A0%9C%ED%95%9C%EC%82%AC%ED%95%AD"},{"level":3,"type":"heading","text":"⚠️ 순환 의존성","anchor":"%E2%9A%A0%EF%B8%8F-%EC%88%9C%ED%99%98-%EC%9D%98%EC%A1%B4%EC%84%B1"},{"type":"codeListing","code":["\/\/ ❌ 피해야 할 패턴","container.register(ServiceA.self) { container.resolve(ServiceB.self)! }","container.register(ServiceB.self) { container.resolve(ServiceA.self)! }","\/\/ 이는 런타임에 무한 루프나 데드락을 유발할 수 있습니다"],"syntax":"swift"},{"level":3,"type":"heading","text":"⚠️ 부트스트랩 타이밍","anchor":"%E2%9A%A0%EF%B8%8F-%EB%B6%80%ED%8A%B8%EC%8A%A4%ED%8A%B8%EB%9E%A9-%ED%83%80%EC%9D%B4%EB%B0%8D"},{"type":"codeListing","code":["\/\/ ❌ 잘못된 사용","class SomeClass {","    init() {","        \/\/ 부트스트랩 완료 전에 resolve 호출 - 위험!","        self.service = DependencyContainer.live.resolve(ServiceProtocol.self)!","    }","}","","\/\/ ✅ 올바른 사용","class SomeClass {","    private let service: ServiceProtocol","    ","    init(service: ServiceProtocol) {","        self.service = service","    }","}"],"syntax":"swift"},{"level":3,"type":"heading","text":"⚠️ 스레드 안전성 주의사항","anchor":"%E2%9A%A0%EF%B8%8F-%EC%8A%A4%EB%A0%88%EB%93%9C-%EC%95%88%EC%A0%84%EC%84%B1-%EC%A3%BC%EC%9D%98%EC%82%AC%ED%95%AD"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"부트스트랩은 앱 시작 시 한 번만 수행하는 것이 좋습니다"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"resetForTesting()"},{"type":"text","text":"은 DEBUG 빌드에서만 사용하세요"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"런타임 업데이트는 필요한 경우에만 신중하게 사용하세요","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"관련 API","anchor":"%EA%B4%80%EB%A0%A8-API"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/ContainerRegister","type":"reference"},{"text":": 프로퍼티 래퍼 기반 의존성 주입","type":"text"}]