y 인스턴스를 주입받아 "},{"type":"codeVoice","code":"Module"},{"type":"text","text":"을 생성하는 클로저를 반환합니다."},{"text":" ","type":"text"},{"text":"내부적으로 ","type":"text"},{"type":"codeVoice","code":"DependencyContainer.live.resolveOrDefault"},{"type":"text","text":"를 통해 등록된 Repository를 조회하고,"},{"type":"text","text":" "},{"type":"text","text":"없을 경우 "},{"code":"repositoryFallback()","type":"codeVoice"},{"text":"을 사용합니다.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let authUseCaseDependency = registerModule.makeUseCaseWithRepository(","    AuthUseCaseProtocol.self,","    repositoryProtocol: AuthRepositoryProtocol.self,","    repositoryFallback: DefaultAuthRepository()",") { repo in","    DefaultAuthUseCase(repository: repo)","}","\/\/ authUseCaseDependency() 호출 시 Module(AuthUseCaseProtocol, DefaultAuthUseCase(repository: resolvedOrFallbackRepo))"]},{"text":"4. resolveOrDefault(_:default:)","level":3,"type":"heading","anchor":"4-resolveOrDefaultdefault"},{"type":"paragraph","inlineContent":[{"type":"text","text":"DI 컨테이너에서 주어진 타입의 인스턴스를 조회하거나, 없으면 "},{"code":"defaultFactory()","type":"codeVoice"},{"text":" 결과를 반환합니다.","type":"text"}]},{"syntax":"swift","code":["let authRepo: AuthRepositoryProtocol =","    registerModule.resolveOrDefault(AuthRepositoryProtocol.self, default: DefaultAuthRepository())"],"type":"codeListing"},{"type":"heading","text":"5. defaultInstance(for:fallback:)","anchor":"5-defaultInstanceforfallback","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"DI 컨테이너에 등록된 인스턴스가 있으면 이를 반환하고, 없으면 "},{"type":"codeVoice","code":"fallback()"},{"type":"text","text":" 결과를 반환합니다."},{"type":"text","text":" "},{"type":"text","text":"내부적으로 "},{"type":"codeVoice","code":"resolveOrDefault(_:default:)"},{"type":"text","text":"를 호출합니다."}]},{"type":"codeListing","code":["let userService: UserServiceProtocol =","    registerModule.defaultInstance(for: UserServiceProtocol.self, fallback: DefaultUserService())"],"syntax":"swift"},{"type":"heading","level":2,"text":"예시 전체 흐름","anchor":"%EC%98%88%EC%8B%9C-%EC%A0%84%EC%B2%B4-%ED%9D%90%EB%A6%84"},{"items":[{"content":[{"inlineContent":[{"text":"Repository 정의","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"code":["import DiContainer","","protocol AuthRepositoryProtocol {","    func login(user: String, password: String) async -> Bool","}","","struct DefaultAuthRepository: AuthRepositoryProtocol {","    func login(user: String, password: String) async -> Bool {","        \/\/ 네트워크 요청 로직...","        return true","    }","}","","extension RepositoryModuleFactory {","    public mutating func registerDefaultDefinitions() {","        \/\/ AuthRepositoryProtocol ↔ DefaultAuthRepository 연결","        repositoryDefinitions = [","            registerModule.makeDependency(","                AuthRepositoryProtocol.self,","                factory: { DefaultAuthRepository() }","            )","        ]","    }","}"],"syntax":"swift","type":"codeListing"},{"start":2,"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"UseCase 정의","type":"text"}]}]}],"type":"orderedList"},{"syntax":"swift","code":["import DiContainer","","protocol AuthUseCaseProtocol {","    func authenticate(user: String, password: String) async -> Bool","}","","struct DefaultAuthUseCase: AuthUseCaseProtocol {","    let repository: AuthRepositoryProtocol","    init(repository: AuthRepositoryProtocol) {","        self.repository = repository","    }","    func authenticate(user: String, password: String) async -> Bool {","        return await repository.login(user: user, password: password)","    }","}","","extension UseCaseModuleFactory {","    public var useCaseDefinitions: [() -> Module] {","        let helper = registerModule","        return [","            helper.makeUseCaseWithRepository(","                AuthUseCaseProtocol.self,","                repositoryProtocol: AuthRepositoryProtocol.self,","                repositoryFallback: DefaultAuthRepository()","            ) { repo in","                DefaultAuthUseCase(repository: repo)","            }","        ]","    }","}"],"type":"codeListing"},{"start":3,"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"AppDIContainer 등록 호출","type":"text"}],"type":"paragraph"}]}]},{"syntax":"swift","code":["import DiContainer","","extension AppDIContainer {","    public func registerDefaultDependencies() async {","        var repoFactory = repositoryFactory","        let useCaseFactoryCopy = useCaseFactory","","        await registerDependencies { container in","            \/\/ Repository 모듈 등록","            repoFactory.registerDefaultDefinitions()","            for module in repoFactory.makeAllModules() {","                await container.register(module)","            }","","            \/\/ UseCase 모듈 등록","            for module in useCaseFactoryCopy.makeAllModules() {","                await container.register(module)","            }","        }","    }","}"],"type":"codeListing"},{"start":4,"items":[{"content":[{"inlineContent":[{"type":"text","text":"앱 초기화 시점 예시"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"codeListing","code":["\/\/ SwiftUI 예시","import SwiftUI","","@main","struct MyApp: App {","    init() {","        Task {","            await AppDIContainer.shared.registerDefaultDependencies()","        }","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","}"],"syntax":"swift"},{"type":"codeListing","code":["\/\/ UIKit AppDelegate 예시","import UIKit","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Task {","            await AppDIContainer.shared.registerDefaultDependencies()","        }","        return true","    }","}"],"syntax":"swift"}]}],"variants":[{"paths":["\/documentation