le 인스턴스 생성","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Factory 패턴"}]},{"text":": 재사용 가능한 의존성 생성 로직","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"🔄 유연한 폴백","level":3,"anchor":"%F0%9F%94%84-%EC%9C%A0%EC%97%B0%ED%95%9C-%ED%8F%B4%EB%B0%B1","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"기본 구현체"}]},{"type":"text","text":": Repository 미등록 시 fallback 제공"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"조건부 등록","type":"text"}],"type":"strong"},{"text":": 의존성 상태에 따른 선택적 등록","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"테스트 지원"}],"type":"strong"},{"text":": Mock 객체 쉬운 교체 가능","type":"text"}]}]}],"type":"unorderedList"},{"text":"주요 기능 개요","level":2,"anchor":"%EC%A3%BC%EC%9A%94-%EA%B8%B0%EB%8A%A5-%EA%B0%9C%EC%9A%94","type":"heading"},{"text":"1. 🏭 기본 모듈 생성","level":3,"anchor":"1-%F0%9F%8F%AD-%EA%B8%B0%EB%B3%B8-%EB%AA%A8%EB%93%88-%EC%83%9D%EC%84%B1","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"makeModule(_:factory:)"}]},{"type":"text","text":": 단순한 타입-팩토리 쌍 모듈 생성"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"makeDependency(_:factory:)"}],"type":"strong"},{"text":": 프로토콜 타입 기반 모듈 클로저 생성","type":"text"}]}]}],"type":"unorderedList"},{"text":"2. 🔗 자동 의존성 주입","level":3,"anchor":"2-%F0%9F%94%97-%EC%9E%90%EB%8F%99-%EC%9D%98%EC%A1%B4%EC%84%B1-%EC%A3%BC%EC%9E%85","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"makeUseCaseWithRepository(_:repositoryProtocol:repositoryFallback:factory:)","type":"codeVoice"}],"type":"strong"},{"type":"text","text":": UseCase에 Repository 자동 주입"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"makeUseCaseWithRepositoryOrNil(_:repositoryProtocol:repositoryFallback:missing:factory:)","type":"codeVoice"}]},{"text":": 조건부 UseCase 생성","type":"text"}]}]}],"type":"unorderedList"},{"text":"3. 🔍 의존성 조회 헬퍼","level":3,"anchor":"3-%F0%9F%94%8D-%EC%9D%98%EC%A1%B4%EC%84%B1-%EC%A1%B0%ED%9A%8C-%ED%97%AC%ED%8D%BC","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"resolveOrDefault(_:default:)"}],"type":"strong"},{"text":": 안전한 의존성 조회","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"defaultInstance(for:fallback:)","type":"codeVoice"}]},{"type":"text","text":": 기본 인스턴스 제공"}]}]}],"type":"unorderedList"},{"text":"역할 및 주요 메서드","level":2,"anchor":"%EC%97%AD%ED%95%A0-%EB%B0%8F-%EC%A3%BC%EC%9A%94-%EB%A9%94%EC%84%9C%EB%93%9C","type":"heading"},{"text":"1. makeModule(_:factory:)","level":3,"anchor":"1-makeModulefactory","type":"heading"},{"inlineContent":[{"text":"주어진 타입 ","type":"text"},{"code":"T","type":"codeVoice"},{"text":"와 팩토리 클로저를 이용해, DI 컨테이너에 등록할 ","type":"text"},{"code":"Module","type":"codeVoice"},{"text":"을 생성합니다.","type":"text"}],"type":"paragraph"},{"code":["let userModule = registerModule.makeModule(","    UserServiceProtocol.self,","    factory: { DefaultUserService() }",")","\/\/ 이후 `container.register(userModule)` 호출 시","\/\/ UserServiceProtocol ↔ DefaultUserService 연결"],"syntax":"swift","type":"codeListing"},{"text":"2. makeDependency(_:factory:)","level":3,"anchor":"2-makeDependencyfactory","type":"heading"},{"inlineContent":[{"text":"특정 프로토콜 타입 ","type":"text"},{"code":"T","type":"codeVoice"},{"text":"에 대해, ","type":"text"},{"code":"Module","type":"codeVoice"},{"text":"을 생성하는 클로저를 반환합니다.","type":"text"}],"type":"paragraph"},{"code":["let authRepoDependency = registerModule.makeDependency(","    AuthRepositoryProtocol.self,","    factory: { DefaultAuthRepository() }",")","\/\/ authRepoDependency() → Module(AuthRepositoryProtocol, DefaultAuthRepository())"],"syntax":"swift","type":"codeListing"},{"text":"3. makeUseCaseWithRepository(_:repositoryProtocol:repositoryFallback:factory:)","level":3,"anchor":"3-makeUseCaseWithRepositoryrepositoryProtocolrepositoryFallbackfactory","type":"heading"},{"inlineContent":[{"text":"UseCase 모듈 생성 시, 자동으로 Repository 인스턴스를 주입받아 ","type":"text"},{"type":"codeVoice","code":"Module"},{"text":"을 생성하는 클로저를 반환합니다.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"내부적으로 "},{"type":"codeVoice","code":"DependencyContainer.live.resolveOrDefault"},{"type":"text","text":"를 통해 등록된 Repository를 조회하고,"},{"type":"text","text":" "},{"type":"text","text":"없을 경우 "},{"type":"codeVoice","code":"repositoryFallback()"},{"type":"text","text":"을 사용합니다."}],"type":"paragraph"},{"code":["let authUseCaseDependency = registerModule.makeUseCaseWithRepository(","    AuthUseCaseProtocol.self,","    repositoryProtocol: AuthRepositoryProtocol.self,","    repositoryFallback: DefaultAuthRepository()",") { repo in","    DefaultAuthUseCase(repository: repo)","}","\/\/ authUseCaseDependency() 호출 시","\/\/ Module(AuthUseCaseProtocol, DefaultAuthUseCase(repository: resolvedOrFallbackRepo))"],"syntax":"swift","type":"codeListing"},{"text":"4. resolveOrDefault(_:default:)","level":3,"anchor":"4-resolveOrDefaultdefault","type":"heading"},{"inlineContent":[{"text":"DI 컨테이너에서 주어진 타입의 인스턴스를 조회하거나, 없으면 ","type":"text"},{"code":"defaultFactory()","type":"codeVoice"},{"text":" 결과를 반환합니다.","type":"text"}],"type":"paragraph"},{"code":["let authRepo: AuthRepositoryProtocol =","    registerModule.resolveOrDefault(AuthRepositoryProtocol.self, default: DefaultAuthRepository())"],"syntax":"swift","type":"codeListing"},{"text":"5. defaultInstance(for:fallback:)","level":3,"anchor":"5-defaultInstanceforfallback","type":"heading"},{"inlineContent":[{"type":"text","text":"DI 컨테이너에 등록된 인스턴스가 있으면 반환하고, 없으면 "},{"type":"codeVoice","code":"fallback()"},{"type":"text","text":" 결과를 반환합니다."}],"type":"paragraph"},{"code":["let userService: UserServiceProtocol =","    registerModule.defaultInstance(for: UserServiceProtocol.self, fallback: DefaultUserService())"],"syntax":"swift","type":"codeListing"},{"text":"예시 전체 흐름","level":2,"anchor":"%EC%98%88%EC%8B%9C-%EC%A0%84%EC%B2%B4-%ED%9D%90%EB%A6%84","type":"heading"},{"text":"1) Repository 정의","level":3,"anchor":"1-Repository-%EC%A0%95%EC%9D%98","type":"heading"},{"code":["import DiContainer","","protocol AuthRepositoryProtocol {","    func login(user: String, password: String) async -> Bool","}","","struct DefaultAuthRepository: AuthRepositoryProtocol {","    func login(user: String, password: String) async -> Bool {","        \/\/ 네트워크 요청 로직...","        return true","    }","}","","extension RepositoryModuleFactory {","    public mutating func registerDefaultDefinitions() {","        repositoryDefinitions = [","            registerModule.makeDependency(","                AuthRepositoryProtocol.self,","                factory: { DefaultAuthRepository() }","            )","        ]","    }","}"],"syntax":"swift","type":"codeListing"},{"text":"2) UseCase 정의","level":3,"anchor":"2-UseCase-%EC%A0%95%EC%9D%98","type":"heading"},{"code":["import DiContainer","","protocol AuthUseCaseProtocol {","    func authenticate(user: String, password: String) async -> Bool","}","","struct DefaultAuthUseCase: AuthUseCaseProtocol {","    let repository: AuthRepositoryProtocol","","    init(repository: AuthRepositoryProtocol) {","        self.repository = repository","    }","","    func authenticate(user: String, password: String) async -> Bool {","        return await repository.login(user: user, password: password)","    }","}","","extension UseCaseModuleFactory {","    public var useCaseDefinitions: [() -> Module] {","        let helper = registerModule","        return [","            helper.makeUseCaseWithRepository(","                AuthUseCaseProtocol.self,","                repositoryProtocol: AuthRepositoryProtocol.self,","                repositoryFallback: DefaultAuthRepository()","            ) { repo in","                DefaultAuthUseCase(repository: repo)","            }","        ]","    }","}"],"syntax":"swift","type":"codeListing"},{"text":"3) AppDIContainer 등록 호출","level":3,"anchor":"3-AppDIContainer-%EB%93%B1%EB%A1%9D-%ED%98%B8%EC%B6%9C","type":"heading"},{"code":["import DiContainer","","extension AppDIContainer {","    public func registerDefaultDependencies() async {","        var repoFactory = repositoryFactory","        let useCaseFactoryCopy = useCaseFactory","","        await registerDependencies { container in","            \/\/ Repository 모듈 등록","            repoFactory.registerDefaultDefinitions()","            for module in repoFactory.makeAllModules() {","                await container.register(module)","            }","","            \/\/ UseCase 모듈 등록","            for module in useCaseFactoryCopy.makeAllModules() {","                await container.register(module)","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"text":"4) 앱 초기화 시점 예시","level":3,"anchor":"4-%EC%95%B1-%EC%B4%88%EA%B8%B0%ED%99%94-%EC%8B%9C%EC%A0%90-%EC%98%88%EC%8B%9C","type":"heading"},{"text":"SwiftUI","level":4,"anchor":"SwiftUI","type":"heading"},{"code":["import SwiftUI","","@main","struct MyApp: App {","    init() {","        Task {","            await AppDIContainer.shared.registerDefaultDependencies()","        }","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"text":"UIKit AppDelegate","level":4,"anchor":"UIKit-AppDelegate","type":"heading"},{"code":["import UIKit","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Task {","            await AppDIContainer.shared.registerDefaultDependencies()","        }","        return true","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"kind":"symbol","references":{"doc://DiContainer/documentation/DiContainer/RegisterModule":{"navigatorTitle":[{"text":"RegisterModule","kind":"identifier"}],"abstract":[],"title":"RegisterModule","role":"symbol","url":"\/documentation\/dicontainer\/registermodule","type":"topic","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/RegisterModule","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RegisterModule","kind":"identifier"}]},"doc://DiContainer/documentation/DiContainer":{"title":"DiContainer","role":"collection","abstract":[],"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer","kind":"symbol","type":"topic","url":"\/documentation\/dicontainer"},"doc://DiContainer/documentation/DiContainer/RegisterModule/resolveOrDefault(_:default:)":{"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/RegisterModule\/resolveOrDefault(_:default:)","type":"topic","url":"\/documentation\/dicontainer\/registermodule\/resolveordefault(_:default:)","kind":"symbol","abstract":[{"text":"DI 컨테이너에서 주어진 타입의 인스턴스를 조회하거나, 없으면 ","type":"text"},{"code":"defaultFactory()","type":"codeVoice"},{"text":" 결과를 반환합니다.","type":"text"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"resolveOrDefault"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"T"},{"kind":"text","text":".Type, "},{"kind":"externalParam","text":"default"},{"kind":"text","text":": "},{"kind":"attribute","text":"@autoclosure "},{"text":"() -> ","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"T","kind":"typeIdentifier"}],"role":"symbol","title":"resolveOrD