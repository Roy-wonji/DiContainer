hRepository() }","            )","        ]","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"2-UseCase-%EC%A0%95%EC%9D%98","type":"heading","level":3,"text":"2) UseCase 정의"},{"code":["import DiContainer","","protocol AuthUseCaseProtocol {","    func authenticate(user: String, password: String) async -> Bool","}","","struct DefaultAuthUseCase: AuthUseCaseProtocol {","    let repository: AuthRepositoryProtocol","","    init(repository: AuthRepositoryProtocol) {","        self.repository = repository","    }","","    func authenticate(user: String, password: String) async -> Bool {","        return await repository.login(user: user, password: password)","    }","}","","extension UseCaseModuleFactory {","    public var useCaseDefinitions: [() -> Module] {","        let helper = registerModule","        return [","            helper.makeUseCaseWithRepository(","                AuthUseCaseProtocol.self,","                repositoryProtocol: AuthRepositoryProtocol.self,","                repositoryFallback: DefaultAuthRepository()","            ) { repo in","                DefaultAuthUseCase(repository: repo)","            }","        ]","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"3-AppDIContainer-%EB%93%B1%EB%A1%9D-%ED%98%B8%EC%B6%9C","type":"heading","level":3,"text":"3) AppDIContainer 등록 호출"},{"code":["import DiContainer","","extension AppDIContainer {","    public func registerDefaultDependencies() async {","        var repoFactory = repositoryFactory","        let useCaseFactoryCopy = useCaseFactory","","        await registerDependencies { container in","            \/\/ Repository 모듈 등록","            repoFactory.registerDefaultDefinitions()","            for module in repoFactory.makeAllModules() {","                await container.register(module)","            }","","            \/\/ UseCase 모듈 등록","            for module in useCaseFactoryCopy.makeAllModules() {","                await container.register(module)","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"4-%EC%95%B1-%EC%B4%88%EA%B8%B0%ED%99%94-%EC%8B%9C%EC%A0%90-%EC%98%88%EC%8B%9C","type":"heading","level":3,"text":"4) 앱 초기화 시점 예시"},{"anchor":"SwiftUI","type":"heading","level":4,"text":"SwiftUI"},{"code":["import SwiftUI","","@main","struct MyApp: App {","    init() {","        Task {","            await AppDIContainer.shared.registerDefaultDependencies()","        }","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"UIKit-AppDelegate","type":"heading","level":4,"text":"UIKit AppDelegate"},{"code":["import UIKit","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Task {","            await AppDIContainer.shared.registerDefaultDependencies()","        }","        return true","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RegisterModule","kind":"identifier"}],"title":"RegisterModule","modules":[{"name":"DiContainer"}],"symbolKind":"struct","navigatorTitle":[{"text":"RegisterModule","kind":"identifier"}],"role":"symbol","externalID":"s:11DiContainer14RegisterModuleV","roleHeading":"Structure"},"identifier":{"url":"doc:\/\/DiContainer\/documentation\/DiContainer\/RegisterModule","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/DiContainer\/documentation\/DiContainer"]]},"sections":[],"kind":"symbol","references":{"#defaultinstance":{"url":"#defaultinstance","titleInlineContent":[{"type":"codeVoice","code":"defaultInstance(for:fallback:)"}],"type":"link","identifier":"#defaultinstance","title":"defaultInstance(for:fallback:)"},"doc://DiContainer/docume