},{"syntax":"swift","code":["import DiContainer","","extension AppDIContainer {","    \/\/\/ 기본 Use Case 모듈을 DI 컨테이너에 등록합니다.","    public func registerDefaultUseCaseModules() async {","        \/\/ 값 타입 복사를 통해 캡처 문제 방지","        let factoryCopy = self.useCaseFactory","","        await registerDependencies { container in","            \/\/ 정의된 모든 Module 인스턴스를 순회하며 Container에 등록","            for module in factoryCopy.makeAllModules() {","                await container.register(module)","            }","        }","    }","}"],"type":"codeListing"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"앱 초기화 시점 예시 (SwiftUI ","type":"text"},{"code":"@main","type":"codeVoice"},{"text":" 또는 UIKit ","type":"text"},{"type":"codeVoice","code":"AppDelegate"},{"text":")","type":"text"}]}]}],"start":4,"type":"orderedList"},{"code":["\/\/ SwiftUI 예시","import SwiftUI","","@main","struct MyApp: App {","    init() {","        Task {","            await AppDIContainer.shared.registerDefaultUseCaseModules()","        }","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"syntax":"swift","code":["\/\/ UIKit 예시 (AppDelegate)","import UIKit","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Task {","            await AppDIContainer.shared.registerDefaultUseCaseModules()","        }","        return true","    }","}"],"type":"codeListing"}]}],"topicSections":[{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/registerModule","doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/useCaseDefinitions"]},{"anchor":"Instance-Met