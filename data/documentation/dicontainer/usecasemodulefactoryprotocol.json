ring, password: String) async -> Bool","}","","struct DefaultAuthUseCase: AuthUseCaseProtocol {","    private let repository: AuthRepositoryProtocol","","    init(repository: AuthRepositoryProtocol) {","        self.repository = repository","    }","","    func authenticate(user: String, password: String) async -> Bool {","        \/\/ Repository를 사용하여 인증 로직 수행","        return await repository.login(user: user, password: password)","    }","}"],"syntax":"swift"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"UseCaseModuleFactoryProtocol"},{"type":"text","text":"을 채택하는 팩토리 타입 생성"}]}]}],"start":2,"type":"orderedList"},{"syntax":"swift","code":["import DiContainer","","extension UseCaseModuleFactory {","    \/\/\/ 기본 Use Case 의존성 정의를 설정합니다.","    \/\/\/ - `AuthUseCaseProtocol` 타입의 `DefaultAuthUseCase` 인스턴스를 생성하고,","    \/\/\/   `AuthRepositoryProtocol`을 자동으로 주입받습니다.","    public var useCaseDefinitions: [() -> Module] {","        let helper = registerModule  \/\/ self를 직접 캡처하지 않도록 복사","        return [","            helper.makeUseCaseWithRepository(","                AuthUseCaseProtocol.self,              \/\/ 등록할 Use Case 프로토콜","                repositoryProtocol: AuthRepositoryProtocol.self,  \/\/ 주입받을 Repository 프로토콜","                repositoryFallback: DefaultAuthRepository()       \/\/ Repository가 없을 때 사용할 기본 인스턴스","            ) { repo in","                DefaultAuthUseCase(repository: repo) \/\/ 주입된 Repository로 생성한 Use Case","            }","        ]","    }","}"],"type":"codeListing"},{"start":3,"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"AppDIContainer"},{"type":"text","text":" 내에서 호출하여 DI 컨테이너에 모든 Use Case 모듈 등록"}]}]}],"type":"orderedList"},{"syntax":"swift","code":["import DiContainer","","extension AppDIContainer {","    \/\/\/ 기본 Use Case 모듈을 DI 컨테이너에 등록합니다.","    public func registerDefaultUseCaseModules() async {","        \/\/ 값 타입 복사를 통해 캡처 문제 방지","        let factoryCopy = self.useCaseFactory","","        await registerDependencies { container in","            \/\/ 정의된 모든 Module 인스턴스를 순회하며 Container에 등록","            for module in factoryCopy.makeAllModules() {","                await container.register(module)","            }","        }","    }","}"],"type":"codeListing"},{"start":4,"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"앱 초기화 시점 예시 (SwiftUI ","type":"text"},{"type":"codeVoice","code":"@main"},{"text":" 또는 UIKit ","type":"text"},{"code":"AppDelegate","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]}]},{"syntax":"swift","type":"codeListing","code":["\/\/ SwiftUI 예시","import SwiftUI","","@main","struct MyApp: App {","    init() {","        Task {","            await AppDIContainer.shared.registerDefaultUseCaseModules()","        }","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","}"]},{"type":"codeListing","syntax":"swift","code":["\/\/ UIKit 예시 (AppDelegate)","import UIKit","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Task {","            await AppDIContainer.shared.registerDefaultUseCaseModules()","        }","        return true","    }","}"]}]}],"references":{"doc://DiContainer/documentation/DiContainer/UseCaseModuleFactoryProtocol":{"url":"\/documentation\/dicontainer\/usecasemodulefactoryprotocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UseCaseModuleFactoryProtocol","kind":"identifier"}],"title":"UseCaseModuleFactoryProtocol","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"UseCaseModuleFactoryProtocol"}],"abstract":[{"type":"codeVoice","cod