":["swift"]}]},{"content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/registerModule"},{"type":"text","text":": Use Case 모듈 생성 시 필요한 의존성을 등록하는 헬퍼("},{"code":"RegisterModule","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/useCaseDefinitions"},{"text":": ","type":"text"},{"code":"Module","type":"codeVoice"},{"text":" 생성 ","type":"text"},{"inlineContent":[{"type":"text","text":"클로저"}],"type":"strong"},{"type":"text","text":"의 목록"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/makeAllModules()","isActive":true,"type":"reference"},{"text":": 위 클로저들을 실행해 ","type":"text"},{"type":"strong","inlineContent":[{"code":"Module","type":"codeVoice"},{"type":"text","text":" 인스턴스 배열"}]},{"type":"text","text":"을 반환"}]}]}]},{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"registerModule","type":"codeVoice"},{"type":"text","text":"을 통해, Use Case가 의존하는 Repository 등을 "},{"type":"strong","inlineContent":[{"type":"text","text":"DI 컨테이너에 선언적으로 등록"}]},{"text":"할 수 있습니다.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"useCaseDefinitions"},{"type":"text","text":"에 모듈을 "},{"type":"strong","inlineContent":[{"text":"목록 형태","type":"text"}]},{"type":"text","text":"로 정의하면, 팩토리의 책임과 의존성 구성이 명확해집니다."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/makeAllModules()","isActive":true},{"type":"text","text":"는 정의된 모든 모듈을 "},{"type":"strong","inlineContent":[{"text":"실제 인스턴스","type":"text"}]},{"type":"text","text":"로 변환하여, 등록 루프에서 바로 사용할 수 있게 합니다."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Usage","type":"heading","text":"Usage","level":2},{"level":3,"type":"heading","anchor":"1-Use-CaseRepository-%EC%A0%95%EC%9D%98","text":"1) Use Case\/Repository 정의"},{"code":["protocol AuthUseCaseProtocol {","  func authenticate(user: String, password: String) async -> Bool","}","","struct DefaultAuthUseCase: AuthUseCaseProtocol {","  private let repository: AuthRepositoryProtocol","  init(repository: AuthRepositoryProtocol) { self.repository = repository }","","  func authenticate(user: String, password: String) async -> Bool {","    await repository.login(user: user, password: password)","  }","}"],"type":"codeListing","syntax":"swift"},{"text":"2) 팩토리에서 모듈 정의","level":3,"anchor":"2-%ED%8C%A9%ED%86%A0%EB%A6%AC%EC%97%90%EC%84%9C-%EB%AA%A8%EB%93%88-%EC%A0%95%EC%9D%98","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"RegisterModule.makeUseCaseWithRepository"},{"text":"를 이용해 ","type":"text"},{"inlineContent":[{"type":"text","text":"Repository 자동 주입"}],"type":"strong"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["extension UseCaseModuleFactory {","  public var useCaseDefinitions: [() -> Module] {","    let helper = registerModule \/\/ self 직접 캡처 회피","    return [","      helper.makeUseCaseWithRepository(","        AuthUseCaseProtocol.self,","        repositoryProtocol: AuthRepositoryProtocol.self,","        repositoryFallback: DefaultAuthRepository() \/\/ (선택) 미등록 시 기본 Repo","      ) { repo in","        DefaultAuthUseCase(repository: repo)","      }","    ]","  }","}"]},{"name":"Tip","style":"tip","content":[{"inlineContent":[{"type":"text","text":""},{"code":"repositoryFallback","type":"codeVoice"},{"type":"text","text":"이 "},{"inlineContent":[{"text":"없어도","type":"text"}],"type":"strong"},{"text":" 동작하게 구성하려면,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"RegisterModule"},{"text":"의 ","type":"text"},{"code":"MissingRepoStrategy","type":"codeVoice"},{"text":"를 ","type":"text"},{"code":".useNoOp { ... }","type":"codeVoice"},{"text":" 또는","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":".skipRegistration()"},{"type":"text","text":"으로 사용하세요(크래시 없이 안전한 부트스트랩)."}],"type":"paragraph"}],"type":"aside"},{"anchor":"3-%EC%BB%A8%ED%85%8C%EC%9D%B4%EB%84%88%EC%97%90-%EC%9D%BC%EA%B4%84-%EB%93%B1%EB%A1%9D","type":"heading","level":3,"text":"3) 컨테이너에 일괄 등록"},{"type":"codeListing","syntax":"swift","code":["extension AppDIContainer {","  public func registerDefaultUseCaseModules() async {","    let factoryCopy = self.useCaseFactory \/\/ 값 복사로 캡처 문제 방지","    await registerDependencies { container in","      for module in factoryCopy.makeAllModules() {","        await container.register(module)","      }","    }","  }","}"]},{"text":"4) 앱 초기화 (SwiftUI \/ UIKit)","level":3,"anchor":"4-%EC%95%B1-%EC%B4%88%EA%B8%B0%ED%99%94-SwiftUI--UIKit","type":"heading"},{"code":["\/\/ SwiftUI","@main","struct MyApp: App {","  init() {","    Task { await AppDIContainer.shared.registerDefaultUseCaseModules() }","  }","  var body: some Scene { WindowGroup { ContentView() } }","}"],"syntax":"swift","type":"codeListing"},{"syntax":"swift","code":["\/\/ UIKit AppDelegate","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","  func application(_ application: UIApplication,","                   didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Task { await AppDIContainer.shared.registerDefaultUseCaseModules() }","    return true","  }","}"],"type":"codeListing"},{"level":2,"text":"Best Practices","type":"heading","anchor":"Best-Practices"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"정의와 등록 분리","type":"text"}],"type