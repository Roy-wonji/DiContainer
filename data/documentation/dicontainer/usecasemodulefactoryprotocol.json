aseProtocol {","  private let repository: AuthRepositoryProtocol","  init(repository: AuthRepositoryProtocol) { self.repository = repository }","","  func authenticate(user: String, password: String) async -> Bool {","    await repository.login(user: user, password: password)","  }","}"],"type":"codeListing","syntax":"swift"},{"level":3,"text":"2) 팩토리에서 모듈 정의","anchor":"2-%ED%8C%A9%ED%86%A0%EB%A6%AC%EC%97%90%EC%84%9C-%EB%AA%A8%EB%93%88-%EC%A0%95%EC%9D%98","type":"heading"},{"type":"paragraph","inlineContent":[{"code":"RegisterModule.makeUseCaseWithRepository","type":"codeVoice"},{"type":"text","text":"를 이용해 "},{"inlineContent":[{"text":"Repository 자동 주입","type":"text"}],"type":"strong"},{"type":"text","text":":"}]},{"code":["extension UseCaseModuleFactory {","  public var useCaseDefinitions: [() -> Module] {","    let helper = registerModule \/\/ self 직접 캡처 회피","    return [","      helper.makeUseCaseWithRepository(","        AuthUseCaseProtocol.self,","        repositoryProtocol: AuthRepositoryProtocol.self,","        repositoryFallback: DefaultAuthRepository() \/\/ (선택) 미등록 시 기본 Repo","      ) { repo in","        DefaultAuthUseCase(repository: repo)","      }","    ]","  }","}"],"syntax":"swift","type":"codeListing"},{"type":"aside","style":"tip","name":"Tip","content":[{"inlineContent":[{"type":"text","text":""},{"code":"repositoryFallback","type":"codeVoice"},{"text":"이 ","type":"text"},{"type":"strong","inlineContent":[{"text":"없어도","type":"text"}]},{"type":"text","text":" 동작하게 구성하려면,"},{"type":"text","text":" "},{"type":"codeVoice","code":"RegisterModule"},{"text":"의 ","type":"text"},{"type":"codeVoice","code":"MissingRepoStrategy"},{"type":"text","text":"를 "},{"type":"codeVoice","code":".useNoOp { ... }"},{"type":"text","text":" 또는"},{"type":"text","text":" "},{"type":"codeVoice","code":".skipRegistration()"},{"text":"으로 사용하세요(크래시 없이 안전한 부트스트랩).","type":"text"}],"type":"paragraph"}]},{"text":"3) 컨테이너에 일괄 등록","type":"heading","level":3,"anchor":"3-%EC%BB%A8%ED