,"      }","    ]","  }","}"],"type":"codeListing"},{"style":"tip","name":"Tip","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"repositoryFallback","type":"codeVoice"},{"text":"이 ","type":"text"},{"inlineContent":[{"type":"text","text":"없어도"}],"type":"strong"},{"text":" 동작하게 구성하려면,","type":"text"},{"text":" ","type":"text"},{"code":"RegisterModule","type":"codeVoice"},{"text":"의 ","type":"text"},{"code":"MissingRepoStrategy","type":"codeVoice"},{"text":"를 ","type":"text"},{"code":".useNoOp { ... }","type":"codeVoice"},{"text":" 또는","type":"text"},{"text":" ","type":"text"},{"code":".skipRegistration()","type":"codeVoice"},{"text":"으로 사용하세요(크래시 없이 안전한 부트스트랩).","type":"text"}],"type":"paragraph"}],"type":"aside"},{"level":3,"text":"3) 컨테이너에 일괄 등록","anchor":"3-%EC%BB%A8%ED%85%8C%EC%9D%B4%EB%84%88%EC%97%90-%EC%9D%BC%EA%B4%84-%EB%93%B1%EB%A1%9D","type":"heading"},{"syntax":"swift","code":["extension AppDIContainer {","  public func registerDefaultUseCaseModules() async {","    let factoryCopy = self.useCaseFactory \/\/ 값 복사로 캡처 문제 방지","    await registerDependencies { container in","      for module in factoryCopy.makeAllModules() {","        await container.register(module)","      }","    }","  }","}"],"type":"codeListing"},{"level":3,"text":"4) 앱 초기화 (SwiftUI \/ UIKit)","anchor":"4-%EC%95%B1-%EC%B4%88%EA%B8%B0%ED%99%94-SwiftUI--UIKit","type":"heading"},{"syntax":"swift","code":["\/\/ SwiftUI","@main","struct MyApp: App {","  init() {","    Task { await AppDIContainer.shared.registerDefaultUseCaseModules() }","  }","  var body: some Scene { WindowGroup { ContentView() } }","}"],"type":"codeListing"},{"syntax":"swift","code":["\/\/ UIKit AppDelegate","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","  func application(_ application: UIApplication,","                   didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Task { await AppDIContainer.shared.registerDefaultUseCaseModules() }","    return true","  }","}"],"type":"codeListing"},{"level":2,"text":"Best Practices","anchor":"Best-Practices","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"정의와 등록 분리","type":"text"}]},{"type":"text","text":": 팩토리에서 “정의”, 컨테이너에서 “등록”을 수행해 책임을 분리하세요."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"캡처 주의"}]},{"type":"text","text":": "},{"type":"codeVoice","code":"useCaseDefinitions"},{"type":"text","text":" 내부에서 "},{"type":"codeVoice","code":"self"},{"type":"text","text":"를 직접 캡처하지 말고 "},{"type":"codeVoice","code":"let helper = registerModule"},{"type":"text","text":"처럼 "},{"type":"strong","inlineContent":[{"text":"값 복사","type":"text"}]},{"type":"text","text":"를 권장합니다."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"안전한 부트스트랩"}]},{"type":"text","text":": 필수 Repo가 미등록일 수 있다면, "},{"code":"MissingRepoStrategy","type":"codeVoice"},{"type":"text","text":"로"},{"type":"text","text":" "},{"code":".useNoOp","type":"codeVoice"},{"type":"text","text":" 또는 "},{"code":".skipRegistration","type":"codeVoice"},{"type":"text","text":"을 사용해 앱 중단 없이 진행하세요."}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/DiContainer\/documentation\/DiContainer"]]},"metadata":{"roleHeading":"Protocol","symbolKind":"protocol","navigatorTitle":[{"text":"UseCaseModuleFactoryProtocol","kind":"identifier"}],"title":"UseCaseModuleFactoryProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"UseCaseModuleFactoryProtocol"}],"role":"symbol","externalID":"s:11DiContainer28UseCaseModuleFactoryProtocolP","modules":[{"name":"DiContainer"}]},"variants":[{"paths":["\/documentation\/dicontainer\/usecasemodulefactoryprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/DiContainer\/documentation\/DiConta