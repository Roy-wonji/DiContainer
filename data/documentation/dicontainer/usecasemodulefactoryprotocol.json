{"topicSections":[{"identifiers":["doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/registerModule","doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/useCaseDefinitions"],"title":"Instance Properties","generated":true,"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/makeAllModules()"],"title":"Instance Methods","generated":true,"anchor":"Instance-Methods"}],"hierarchy":{"paths":[["doc:\/\/DiContainer\/documentation\/DiContainer"]]},"identifier":{"url":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol","interfaceLanguage":"swift"},"seeAlsoSections":[{"identifiers":["doc:\/\/DiContainer\/documentation\/DiContainer\/RegisterModule","doc:\/\/DiContainer\/documentation\/DiContainer\/Module"],"title":"Related Documentation","anchor":"Related-Documentation"}],"relationshipsSections":[{"identifiers":["doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactory"],"title":"Conforming Types","kind":"relationships","type":"conformingTypes"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"UseCaseModuleFactoryProtocol"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/registerModule","isActive":true,"type":"reference"},{"type":"text","text":": Use Case 모듈 생성 시 필요한 의존성을 등록하는 헬퍼("},{"type":"codeVoice","code":"RegisterModule"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/useCaseDefinitions"},{"text":": ","type":"text"},{"type":"codeVoice","code":"Module"},{"text":" 생성 ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"클로저"}]},{"text":"의 목록","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/makeAllModules()","type":"reference","isActive":true},{"type":"text","text":": 위 클로저들을 실행해 "},{"type":"strong","inlineContent":[{"code":"Module","type":"codeVoice"},{"type":"text","text":" 인스턴스 배열"}]},{"type":"text","text":"을 반환"}]}]}],"type":"orderedList"},{"text":"Overview","level":2,"type":"heading","anchor":"Overview"},{"items":[{"content":[{"inlineContent":[{"code":"registerModule","type":"codeVoice"},{"text":"을 통해, Use Case가 의존하는 Repository 등을 ","type":"text"},{"type":"strong","inlineContent":[{"text":"DI 컨테이너에 선언적으로 등록","type":"text"}]},{"text":"할 수 있습니다.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"useCaseDefinitions","type":"codeVoice"},{"text":"에 모듈을 ","type":"text"},{"inlineContent":[{"text":"목록 형태","type":"text"}],"type":"strong"},{"text":"로 정의하면, 팩토리의 책임과 의존성 구성이 명확해집니다.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol\/makeAllModules()"},{"text":"는 정의된 모든 모듈을 ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"실제 인스턴스"}]},{"text":"로 변환하여, 등록 루프에서 바로 사용할 수 있게 합니다.","type":"text"}]}]}],"type":"unorderedList"},{"text":"Usage","level":2,"type":"heading","anchor":"Usage"},{"text":"1) Use Case\/Repository 정의","level":3,"type":"heading","anchor":"1-Use-CaseRepository-%EC%A0%95%EC%9D%98"},{"syntax":"swift","code":["protocol AuthUseCaseProtocol {","  func authenticate(user: String, password: String) async -> Bool","}","","struct DefaultAuthUseCase: AuthUseCaseProtocol {","  private let repository: AuthRepositoryProtocol","  init(repository: AuthRepositoryProtocol) { self.repository = repository }","","  func authenticate(user: String, password: String) async -> Bool {","    await repository.login(user: user, password: password)","  }","}"],"type":"codeListing"},{"text":"2) 팩토리에서 모듈 정의","level":3,"type":"heading","anchor":"2-%ED%8C%A9%ED%86%A0%EB%A6%AC%EC%97%90%EC%84%9C-%EB%AA%A8%EB%93%88-%EC%A0%95%EC%9D%98"},{"inlineContent":[{"type":"codeVoice","code":"RegisterModule.makeUseCaseWithRepository"},{"type":"text","text":"를 이용해 "},{"inlineContent":[{"text":"Repository 자동 주입","type":"text"}],"type":"strong"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["extension UseCaseModuleFactory {","  public var useCaseDefinitions: [() -> Module] {","    let helper = registerModule \/\/ self 직접 캡처 회피","    return [","      helper.makeUseCaseWithRepository(","        AuthUseCaseProtocol.self,","        repositoryProtocol: AuthRepositoryProtocol.self,","        repositoryFallback: DefaultAuthRepository() \/\/ (선택) 미등록 시 기본 Repo","      ) { repo in","        DefaultAuthUseCase(repository: repo)","      }","    ]","  }","}"],"type":"codeListing"},{"name":"Tip","style":"tip","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"repositoryFallback"},{"type":"text","text":"이 "},{"type":"strong","inlineContent":[{"text":"없어도","type":"text"}]},{"type":"text","text":" 동작하게 구성하려면,"},{"type":"text","text":" "},{"type":"codeVoice","code":"RegisterModule"},{"type":"text","text":"의 "},{"type":"codeVoice","code":"MissingRepoStrategy"},{"type":"text","text":"를 "},{"type":"codeVoice","code":".useNoOp { ... }"},{"type":"text","text":" 또는"},{"type":"text","text":" "},{"type":"codeVoice","code":".skipRegistration()"},{"type":"text","text":"으로 사용하세요(크래시 없이 안전한 부트스트랩)."}],"type":"paragraph"}],"type":"aside"},{"text":"3) 컨테이너에 일괄 등록","level":3,"type":"heading","anchor":"3-%EC%BB%A8%ED%85%8C%EC%9D%B4%EB%84%88%EC%97%90-%EC%9D%BC%EA%B4%84-%EB%93%B1%EB%A1%9D"},{"syntax":"swift","code":["extension AppDIContainer {","  public func registerDefaultUseCaseModules() async {","    let factoryCopy = self.useCaseFactory \/\/ 값 복사로 캡처 문제 방지","    await registerDependencies { container in","      for module in factoryCopy.makeAllModules() {","        await container.register(module)","      }","    }","  }","}"],"type":"codeListing"},{"text":"4) 앱 초기화 (SwiftUI \/ UIKit)","level":3,"type":"heading","anchor":"4-%EC%95%B1-%EC%B4%88%EA%B8%B0%ED%99%94-SwiftUI--UIKit"},{"syntax":"swift","code":["\/\/ SwiftUI","@main","struct MyApp: App {","  init() {","    Task { await AppDIContainer.shared.registerDefaultUseCaseModules() }","  }","  var body: some Scene { WindowGroup { ContentView() } }","}"],"type":"codeListing"},{"syntax":"swift","code":["\/\/ UIKit AppDelegate","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","  func application(_ application: UIApplication,","                   didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","    Task { await AppDIContainer.shared.registerDefaultUseCaseModules() }","    return true","  }","}"],"type":"codeListing"},{"text":"Best Practices","level":2,"type":"heading","anchor":"Best-Practices"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"정의와 등록 분리","type":"text"}]},{"type":"text","text":": 팩토리에서 “정의”, 컨테이너에서 “등록”을 수행해 책임을 분리하세요."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"캡처 주의"}],"type":"strong"},{"text":": ","type":"text"},{"code":"useCaseDefinitions","type":"codeVoice"},{"text":" 내부에서 ","type":"text"},{"code":"self","type":"codeVoice"},{"text":"를 직접 캡처하지 말고 ","type":"text"},{"code":"let helper = registerModule","type":"codeVoice"},{"text":"처럼 ","type":"text"},{"inlineContent":[{"type":"text","text":"값 복사"}],"type":"strong"},{"text":"를 권장합니다.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineCo