g"},{"level":3,"text":"2) 팩토리에서 모듈 정의","anchor":"2-%ED%8C%A9%ED%86%A0%EB%A6%AC%EC%97%90%EC%84%9C-%EB%AA%A8%EB%93%88-%EC%A0%95%EC%9D%98","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"RegisterModule.makeUseCaseWithRepository"},{"text":"를 이용해 ","type":"text"},{"inlineContent":[{"type":"text","text":"Repository 자동 주입"}],"type":"strong"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["extension UseCaseModuleFactory {","  public var useCaseDefinitions: [() -> Module] {","    let helper = registerModule \/\/ self 직접 캡처 회피","    return [","      helper.makeUseCaseWithRepository(","        AuthUseCaseProtocol.self,","        repositoryProtocol: AuthRepositoryProtocol.self,","        repositoryFallback: DefaultAuthRepository() \/\/ (선택) 미등록 시 기본 Repo","      ) { repo in","        DefaultAuthUseCase(repository: repo)","      }","    ]","  }","}"],"type":"codeListing"},{"name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"repositoryFallback"},{"type":"text","text":"이 "},{"type":"strong","inlineContent":[{"text":"없어도","type":"text"}]},{"type":"text","text":" 동작하게 구성하려면,"},{"type":"text","text":" "},{"type":"codeVoice","code":"RegisterModule"},{"type":"text","text":"의 "},{"type":"codeVoice","code":"MissingRepoStrategy"},{"type":"text","text":"를 "},{"type":"codeVoice","code":".useNoOp { ... }"},{"type":"text","text":" 또는"},{"type":"text","text":" "},{"type":"codeVoice","code":".skipRegistration()"},{"type":"text","text":"으로 사용하세요(크래시 없이 안전한 부트스트랩)."}]}],"style":"tip","type":"aside"},{"level":3,"text":"3) 컨테이너에 일괄 등록","anchor":"3-%EC%BB%A8%ED%85%8C%EC%9D%B4%EB%84%88%EC%97%90-%EC%9D%BC%EA%B4%84-%EB%93%B1%EB%A1%9D","type":"heading"},{"syntax":"swift","code":["extension AppDIContainer {","  public func registerDefaultUseCaseModules() async {","    let factoryCopy = self.useCaseFactory \/\/ 값 복사로 캡처 문제 방지","    await registerDependencies { container in","      for module in factor