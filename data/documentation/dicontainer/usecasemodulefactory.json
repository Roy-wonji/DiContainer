eModuleFactoryProtocol","type":"codeVoice"},{"text":"을 채택하는 팩토리 타입 생성","type":"text"}],"type":"paragraph"}]}],"start":2},{"syntax":"swift","code":["import DiContainer","","extension UseCaseModuleFactory {","    \/\/\/ 기본 Use Case 의존성 정의를 설정합니다.","    \/\/\/ 내부에서 `AuthUseCaseProtocol` 타입에 대해 `DefaultAuthUseCase`를 생성하고,","    \/\/\/ `AuthRepositoryProtocol`을 자동으로 주입받도록 합니다.","    public var useCaseDefinitions: [() -> Module] {","        let helper = registerModule  \/\/ self를 직접 캡처하지 않기 위해 복사","        return [","            helper.makeUseCaseWithRepository(","                AuthUseCaseProtocol.self,              \/\/ 주입할 Use Case 프로토콜","                repositoryProtocol: AuthRepositoryProtocol.self,  \/\/ 주입받을 Repository 프로토콜","                repositoryFallback: DefaultAuthRepository()       \/\/ Repository가 없을 때 사용할 기본 인스턴스","            ) { repo in","                DefaultAuthUseCase(repository: repo) \/\/ Repository가 주입되어 생성된 Use Case 인스턴스","            }","        ]","    }","}"],"type":"codeListing"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"AppDIContainer"},{"type":"text","text":" 내에서 호출하여 DI 컨테이너에 모든 Use Case 모듈 등록"}]}]}],"start":3},{"syntax":"swift","type":"codeListing","code":["import DiContainer","","extension AppDIContainer {","    \/\/\/ 기본 Use Case 모듈을 DI 컨테이너에 등록합니다.","    public func registerDefaultUseCaseModules() async {","        let factoryCopy = self.useCaseFactory  \/\/ 값 타입 복사를 통해 캡처 문제 방지","","        await registerDependencies { container in","            \/\/ factoryCopy.useCaseDefinitions를 통해 정의된 모든 Module 인스턴스를 순회하며 등록","            for module in factoryCopy.makeAllModules() {","                await container.register(module)","            }","        }","    }","}"]},{"start":4,"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"실제 앱 초기화 시점 예시 (SwiftUI "},{"type":"codeVoice","code":"@main"},{"type":"text","text":" 또는 UIKit "},{"type":"codeVoice","code":"AppDelegate"},{"text":")","type":"text"}]}]}],"type":"orderedList"},{"type":"codeListing","syntax":"swift","code":["\/\/ SwiftUI 예시","import SwiftUI","","@main","struct MyApp: App {","    init() {","        Task {","            await AppDIContainer.shared.registerDefaultUseCaseModules()","        }","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","}"]},{"type":"codeListing","syntax":"swift","code":["\/\/ UIKit 예시 (AppDelegate)","import UIKit","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Task {","            await AppDIContainer.shared.registerDefaultUseCaseModules()","        }","        return true","    }","}"]}]}],"sections":[],"references":{"doc://DiContainer/documentation/DiContainer/UseCaseModuleFactory/useCaseDefinitions":{"abstract":[{"type":"text","text":"Use Case 모듈을 생성하는 클로저들의 배열."},{"type":"text","text":" "},{"text":"각 클로저는 호출 시 ","type":"text"},{"code":"Module","type":"codeVoice"},{"type":"text","text":" 인스턴스를 반환합니다."}],"kind":"symbol","url":"\/documentation\/dicontainer\/usecasemodulefactory\/usecasedefinitions","role":"symbol","title":"useCaseDefinitions","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useCaseDefinitions"},{"text":": [() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:11DiContainer6ModuleC","text":"Module"},{"text":"]","kind":"text"}],"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactory\/useCaseDefinitions","type":"topic"},"doc://DiContainer/documentation/DiContainer/UseCaseModuleFactory/init()":{"kind":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"()","kind":"text"}],"title":"init()","abstract":[{"text":"기본 생성자.","type":"text"},{"