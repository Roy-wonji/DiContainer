{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/DiContainer\/documentation\/DiContainer"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactory"},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"UseCaseModuleFactory","modules":[{"name":"DiContainer"}],"symbolKind":"struct","externalID":"s:11DiContainer20UseCaseModuleFactoryV","roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"UseCaseModuleFactory"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"UseCaseModuleFactory"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"UseCaseModuleFactory","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"registerModule","type":"codeVoice"},{"text":": 의존성 등록 헬퍼 객체(","type":"text"},{"type":"codeVoice","code":"RegisterModule"},{"type":"text","text":")입니다."},{"type":"text","text":" "},{"type":"text","text":"이 객체를 통해 Use Case 모듈이 필요로 하는 Repository 등 다른 의존성을 DI 컨테이너에 등록할 수 있습니다."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"useCaseDefinitions","type":"codeVoice"},{"text":": Use Case 모듈을 생성하는 클로저들의 배열입니다.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"각 클로저는 호출 시 "},{"type":"codeVoice","code":"Module"},{"type":"text","text":" 인스턴스를 반환합니다."},{"text":" ","type":"text"},{"text":"기본 구현에서는 빈 배열을 반환하므로, 앱 측에서는 ","type":"text"},{"type":"codeVoice","code":"extension"},{"type":"text","text":"을 통해 원하는 모듈 정의를 추가하여 재정의해야 합니다."}]}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"%EC%82%AC%EC%9A%A9-%EC%98%88%EC%8B%9C","text":"사용 예시"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use Case 프로토콜 및 구현체 작성","type":"text"}]}]}]},{"code":["import Foundation","","protocol AuthUseCaseProtocol {","    func authenticate(user: String, password: String) async -> Bool","}","","struct DefaultAuthUseCase: AuthUseCaseProtocol {","    private let repository: AuthRepositoryProtocol","","    init(repository: AuthRepositoryProtocol) {","        self.repository = repository","    }","","    func authenticate(user: String, password: String) async -> Bool {","        \/\/ Repository를 사용하여 인증 로직 수행","        return await repository.login(user: user, password: password)","    }","}"],"type":"codeListing","syntax":"swift"},{"start":2,"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"UseCaseModuleFactoryProtocol"},{"type":"text","text":"을 채택하는 팩토리 타입 생성"}],"type":"paragraph"}]}]},{"syntax":"swift","type":"codeListing","code":["import DiContainer","","extension UseCaseModuleFactory {","    \/\/\/ 기본 Use Case 의존성 정의를 설정합니다.","    \/\/\/ 내부에서 `AuthUseCaseProtocol` 타입에 대해 `DefaultAuthUseCase`를 생성하고,","    \/\/\/ `AuthRepositoryProtocol`을 자동으로 주입받도록 합니다.","    public var useCaseDefinitions: [() -> Module] {","        let helper = registerModule  \/\/ self를 직접 캡처하지 않기 위해 복사","        return [","            helper.makeUseCaseWithRepository(","                AuthUseCaseProtocol.self,              \/\/ 주입할 Use Case 프로토콜","                repositoryProtocol: AuthRepositoryProtocol.self,  \/\/ 주입받을 Repository 프로토콜","                repositoryFallback: DefaultAuthRepository()       \/\/ Repository가 없을 때 사용할 기본 인스턴스","            ) { repo in","                DefaultAuthUseCase(repository: repo) \/\/ Repository가 주입되어 생성된 Use Case 인스턴스","            }","        ]","    }","}"]},{"start":3,"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"AppDIContainer"},{"type":"text","text":" 내에서 호출하여 DI 컨테이너에 모든 Use Case 모듈 등록"}]}]}],"type":"orderedList"},{"type":"codeListing","code":["import DiContainer","","extension AppDIContainer {","    \/\/\/ 기본 Use Case 모듈을 DI 컨테이너에 등록합니다.","    public func registerDefaultUseCaseModules() async {","        let factoryCopy = self.useCaseFactory  \/\/ 값 타입 복사를 통해 캡처 문제 방지","","        await registerDependencies { container in","            \/\/ factoryCopy.useCaseDefinitions를 통해 정의된 모든 Module 인스턴스를 순회하며 등록","            for module in factoryCopy.makeAllModules() {","                await container.register(module)","            }","        }","    }","}"],"syntax":"swift"},{"start":4,"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"실제 앱 초기화 시점 예시 (SwiftUI "},{"code":"@main","type":"codeVoice"},{"type":"text","text":" 또는 UIKit "},{"code":"AppDelegate","type":"codeVoice"},{"type":"text","text":")"}]}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ SwiftUI 예시","import SwiftUI","","@main","struct MyApp: App {","    init() {","        Task {","            await AppDIContainer.shared.registerDefaultUseCaseModules()","        }","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","        }","    }","}"]},{"type":"codeListing","code":["\/\/ UIKit 예시 (AppDelegate)","import UIKit","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","        Task {","            await AppDIContainer.shared.registerDefaultUseCaseModules()","        }","        return true","    }","}"],"syntax":"swift"}],"kind":"content"}],"relationshipsSections":[{"identifiers":["doc:\/\/DiContainer\/documentation\/DiContainer\/UseCaseModuleFactoryProtocol"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/dicontainer\/usecasemodulefactory"]}],"sections":[],"topicSections":[{"identifiers":["