rvice: NetworkService","","    func loadContent() async {","        do {","            let data = try await networkService.fetchData(endpoint: \"\/posts\")","            print(\"Received data:\", data)","        } catch {","            print(\"Error fetching data:\", error)","        }","    }","}"]}]}],"references":{"doc://DiContainer/documentation/DiContainer/ContainerResgister/wrappedValue":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/ContainerResgister\/wrappedValue","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"wrappedValue","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"T"}],"type":"topic","url":"\/documentation\/dicontainer\/containerresgister\/wrappedvalue","title":"wrappedValue","abstract":[{"type":"text","text":"전역 "},{"type":"codeVoice","code":"DependencyContainer.live"},{"type":"text","text":"에서 "},{"type":"codeVoice","code":"keyPath"},{"text":"를 통해 ","type":"text"},{"code":"T","type":"codeVoice"},{"type":"text","text":" 타입의 의존성을 가져옵니다."},{"type":"text","text":" "},{"type":"text","text":"만약 해당 의존성이 "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"일 경우, 런타임에서 즉시 "},{"code":"fatalError","type":"codeVoice"},{"type":"text","text":"가 발생합니다."}]},"doc://DiContainer/documentation/DiContainer/ContainerResgister":{"title":"ContainerResgister","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ContainerResgister","kind":"identifier"}],"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/ContainerResgister","abstract":[{"code":"ContainerResgister","type":"codeVoice"},{"type":"text","text":"는 전역 "},{"type":"codeVoice","code":"DependencyContainer"},{"type":"text","text":"에서 특정 타입의 의존성을 가져오는 프로퍼티 래퍼입니다."}],"navigatorTitle":[{"text":"ContainerResgister","kind":"identifier"}],"kind":"symbol","type":"topic","role":"symbol","url":"\/documentation\/dicontainer\/containerresgister"},"doc://DiContainer/d