{"metadata":{"roleHeading":"Article","modules":[{"name":"DiContainer"}],"title":"Core APIs","role":"article"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/DiContainer\/documentation\/DiContainer"]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"DiContainer provides three main API entry points, each designed for different use cases and complexity levels. This guide covers all core APIs and their intended usage patterns."}]},{"type":"heading","level":2,"text":"API Hierarchy","anchor":"API-Hierarchy"},{"type":"heading","level":3,"text":"UnifiedDI (Recommended)","anchor":"UnifiedDI-Recommended"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The most comprehensive API with all features available."}]},{"type":"heading","level":3,"text":"DI (Simplified)","anchor":"DI-Simplified"},{"type":"paragraph","inlineContent":[{"text":"A streamlined API for basic dependency injection needs.","type":"text"}]},{"type":"heading","level":3,"text":"DIAsync (Async-First)","anchor":"DIAsync-Async-First"},{"type":"paragraph","inlineContent":[{"text":"Specialized API for async\/await heavy applications.","type":"text"}]},{"type":"heading","level":2,"text":"UnifiedDI API","anchor":"UnifiedDI-API"},{"type":"heading","level":3,"text":"Registration Methods","anchor":"Registration-Methods"},{"type":"heading","level":4,"text":"Basic Registration","anchor":"Basic-Registration"},{"syntax":"swift","type":"codeListing","code":["\/\/ Register a type with a factory closure","UnifiedDI.register(ServiceProtocol.self) { ServiceImpl() }","","\/\/ Register with dependency injection","UnifiedDI.register(ComplexService.self) {","    ComplexService(","        dependency1: UnifiedDI.requireResolve(Dependency1.self),","        dependency2: UnifiedDI.resolve(Dependency2.self, default: DefaultDep2())","    )","}"]},{"type":"heading","level":4,"text":"Conditional Registration","anchor":"Conditional-Registration"},{"syntax":"swift","type":"codeListing","code":["\/\/ Register different implementations based on conditions","UnifiedDI.registerIf(","    APIService.self,","    condition: isProduction,","    factory: { ProductionAPIService() },","    fallback: { MockAPIService() }",")","","\/\/ Multiple conditions","UnifiedDI.registerIf(","    LoggerService.self,","    condition: isDebugMode && verboseLogging,","    factory: { VerboseLogger() },","    fallback: { StandardLogger() }",")"]},{"type":"heading","level":4,"text":"Batch Registration","anchor":"Batch-Registration"},{"syntax":"swift","type":"codeListing","code":["\/\/ Register multiple dependencies at once","UnifiedDI.registerMany {","    Registration(NetworkService.self) { URLSessionNetworkService() }","    Registration(CacheService.self) { NSCacheService() }","    Registration(Logger.self) { OSLogger() }","","    \/\/ Conditional registration within batch","    Registration(AnalyticsService.self,","                condition: !isDebugMode,","                factory: { FirebaseAnalytics() },","                fallback: { NoOpAnalytics() })","}"]},{"type":"heading","level":4,"text":"KeyPath Registration","anchor":"KeyPath-Registration"},{"syntax":"swift","type":"codeListing","code":["\/\/ Extend DependencyContainer for KeyPath support","extension DependencyContainer {","    var userService: UserService? { resolve(UserService.self) }","    var apiClient: APIClient? { resolve(APIClient.self) }","}","","\/\/ Register and get instance immediately","let service = UnifiedDI.register(\\.userService) { UserServiceImpl() }","","\/\/ The service is now both registered and available as 'service'"]},{"type":"heading","level":3,"text":"Resolution Methods","anchor":"Resolution-Methods"},{"type":"heading","level":4,"text":"Basic Resolution","anchor":"Basic-Resolution"},{"syntax":"swift","type":"codeListing","code":["\/\/ Optional resolution","let service: ServiceProtocol? = UnifiedDI.resolve(ServiceProtocol.self)","","\/\/ Required resolution (crashes if not found)","let required: ServiceProtocol = UnifiedDI.requireResolve(ServiceProtocol.self)","","\/\/ Resolution with default value","let withDefault = UnifiedDI.resolve(ServiceProtocol.self, default: DefaultService())"]},{"type":"heading","level":4,"text":"Error Handling Resolution","anchor":"Error-Handling-Resolution"},{"syntax":"swift","type":"codeListing","code":["\/\/ Throwing resolution","do {","    let service = try UnifiedDI.resolveThrows(ServiceProtocol.self)","    \/\/ Use service","} catch DIError.dependencyNotFound(let type) {","    print(\"Service not found: \\(type)\")","} catch {","    print(\"Resolution error: \\(error)\")","}"]},{"type":"heading","level":4,"text":"Performance Tracking Resolution","anchor":"Performance-Tracking-Resolution"},{"syntax":"swift","type":"codeListing","code":["\/\/ Resolution with performance tracking","let service = UnifiedDI.resolveWithTracking(ServiceProtocol.self)","","\/\/ Get performance metrics","let metrics = UnifiedDI.getPerformanceMetrics()","print(\"Average resolution time: \\(metrics.averageResolutionTime)ms\")"]},{"type":"heading","level":3,"text":"Management Methods","anchor":"Management-Methods"},{"type":"heading","level":4,"text":"Lifecycle Management","anchor":"Lifecycle-Management"},{"syntax":"swift","type":"codeListing","code":["\/\/ Release specific type","UnifiedDI.release(ServiceProtocol.self)","","\/\/ Release all dependencies","UnifiedDI.releaseAll()","","\/\/ Check if type is registered","if UnifiedDI.isRegistered(ServiceProtocol.self) {","    \/\/ Type is available","}"]},{"type":"heading","level":4,"text":"Introspection","anchor":"Introspection"},{"syntax":"swift","type":"codeListing","code":["\/\/ Get list of registered types","let registeredTypes = UnifiedDI.getRegisteredTypes()","","\/\/ Get dependency graph","let graph = UnifiedDI.getDependencyGraph()","","\/\/ Validate dependency graph for circular dependencies","let validation = UnifiedDI.validateDependencyGraph()"]},{"type":"heading","level":2,"text":"DI API (Simplified)","anchor":"DI-API-Simplified"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The simplified DI API focuses on the most common operations:"}]},{"type":"heading","level":3,"text":"Core Operations","anchor":"Core-Operations"},{"syntax":"swift","type":"codeListing","code":["\/\/ Registration","DI.register(Service.self) { ServiceImpl() }","","\/\/ Resolution","let service = DI.resolve(Service.self)","","\/\/ Required resolution","let required = DI.requireResolve(Service.self)","","\/\/ KeyPath registration (returns instance)","let instance = DI.register(\\.myService) { MyServiceImpl() }"]},{"type":"heading","level":3,"text":"Conditional Registration","anchor":"Conditional-Registration"},{"syntax":"swift","type":"codeListing","code":["\/\/ Simple conditional registration","DI.registerIf(","    Service.self,","    condition: isProduction,","    factory: { ProductionService() },","    fallback: { MockService() }",")"]},{"type":"heading","level":2,"text":"DIAsync API","anchor":"DIAsync-API"},{"type":"paragraph","inlineContent":[{"text":"For async-heavy applications, DIAsync provides async\/await optimized operations:","type":"text"}]},{"type":"heading","level":3,"text":"Async Registration","anchor":"Async-Registration"},{"syntax":"swift","type":"codeListing","code":["\/\/ Register async factory","await DIAsync.register(DatabaseService.self) {","    await DatabaseService.initialize()","}","","\/\/ Batch async registration","await DIAsync.registerMany {","    DIAsyncRegistration(Service1.self) { await Service1.create() }","    DIAsyncRegistration(Service2.self) { Service2() }","}"]},{"type":"heading","level":3,"text":"Async Resolution","anchor":"Async-Resolution"},{"syntax":"swift","type":"codeListing","code":["\/\/ Async resolution","let service = await DIAsync.resolve(ServiceProtocol.self)","","\/\/ Required async resolution","let required = await DIAsync.requireResolve(ServiceProtocol.self)","","\/\/ Async resolution with default","let withDefault = await DIAsync.resolve(ServiceProtocol.self, default: DefaultService())"]},{"type":"heading","level":3,"text":"Async KeyPath Operations","anchor":"Async-KeyPath-Operations"},{"syntax":"swift","type":"codeListing","code":["\/\/ Async KeyPath registration","let service = await DIAsync.register(\\.databaseService) {","    await DatabaseService.initialize()","}","","\/\/ Get or create (idempotent)","let service = await DIAsync.getOrCreate(\\.expensiveService) {","    await ExpensiveService.create()","}"]},{"type":"heading","level":2,"text":"DependencyContainer Core","anchor":"DependencyContainer-Core"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The underlying container that powers all APIs:"}]},{"type":"heading","level":3,"text":"Bootstrap System","anchor":"Bootstrap-System"},{"syntax":"swift","type":"codeListing","code":["\/\/ Synchronous bootstrap","await DependencyContainer.bootstrap { container in","    container.register(Service1.self) { Service1Impl() }","    container.register(Service2.self) { Service2Impl() }","}","","\/\/ Async bootstrap for async dependencies","await DependencyContainer.bootstrapAsync { container in","    let database = await Database.initialize()","    container.register(Database.self, instance: database)","}"]},{"type":"heading","level":3,"text":"Direct Container Operations","anchor":"Direct-Container-Operations"},{"syntax":"swift","type":"codeListing","code":["\/\/ Access live container","let container = DependencyContainer.live","","\/\/ Register directly","container.register(Service.self) { ServiceImpl() }","","\/\/ Register instance directly","let logger = Logger()","container.register(Logger.self, instance: logger)","","\/\/ Resolve directly","let service = container.resolve(Service.self)"]},{"type":"heading","level":3,"text":"Testing Support","anchor":"Testing-Support"},{"syntax":"swift","type":"codeListing","code":["\/\/ Reset container for testing","await DependencyContainer.resetForTesting()","","\/\/ Create isolated test container","let testContainer = DependencyContainer.createIsolated()","","\/\/ Use test container","testContainer.register(MockService.self) { MockServiceImpl() }"]},{"type":"heading","level":2,"text":"Property Wrappers","anchor":"Property-Wrappers"},{"type":"heading","level":3,"text":"@Inject","anchor":"Inject"},{"syntax":"swift","type":"codeListing","code":["class MyService {","    \/\/ Optional injection","    @Inject var optionalDep: OptionalService?","","    \/\/ Required injection (non-optional type)","    @Inject var requiredDep: RequiredService","","    \/\/ KeyPath injection","    @Inject(\\.customService) var customDep: CustomService?","}"]},{"type":"heading","level":3,"text":"@RequiredInject","anchor":"RequiredInject"},{"syntax":"swift","type":"codeListing","code":["class MyService {","    \/\/ Always required, clearer intent","    @RequiredInject var database: Database","    @RequiredInject var logger: Logger","","    \/\/ KeyPath version","    @RequiredInject(\\.apiClient) var apiClient: APIClient","}"]},{"type":"heading","level":3,"text":"@Factory","anchor":"Factory"},{"syntax":"swift","type":"codeListing","code":["class MyService {","    \/\/ Factory-based injection (creates new instance each time)","    @Factory var temporaryService: TemporaryService","","    \/\/ With parameters","    @Factory var configuredService: ConfiguredService","}"]},{"type":"heading","level":2,"text":"Error Handling","anchor":"Error-Handling"},{"type":"heading","level":3,"text":"DIError Types","anchor":"DIError-Types"},{"syntax":"swift","type":"codeListing","code":["enum DIError: Error {","    case dependencyNotFound(Any.Type)","    case circularDependency([Any.Type])","    case registrationConflict(Any.Type)","    case containerNotInitialized","}"]},{"type":"heading","level":3,"text":"Error Handling Patterns","anchor":"Error-Handling-Patterns"},{"syntax":"swift","type":"codeListing","code":["\/\/ Safe resolution with error handling","func safeResolve<T>(_ type: T.Type) -> T? {","    do {","        return try UnifiedDI.resolveThrows(type)","    } catch DIError.dependencyNotFound {","        print(\"Warning: \\(type) not registered\")","        return nil","    } catch {","        print(\"Unexpected error: \\(error)\")","        return nil","    }","}","","\/\/ Graceful degradation","func getServiceWithFallback() -> ServiceProtocol {","    return UnifiedDI.resolve(ServiceProtocol.self) ?? DefaultService()","}"]},{"type":"heading","level":2,"text":"Performance Considerations","anchor":"Performance-Considerations"},{"type":"heading","level":3,"text":"Optimization Tips","anchor":"Optimization-Tips"},{"syntax":"swift","type":"codeListing","code":["\/\/ 1. Use batch registration for related dependencies","UnifiedDI.registerMany {","    Registration(A.self) { AImpl() }","    Registration(B.self) { BImpl() }","    Registration(C.self) { CImpl() }","}","","\/\/ 2. Prefer property wrappers for frequently accessed dependencies","class FrequentlyUsedService {","    @Inject var cache: CacheService? \/\/ Cached after first access","}","","\/\/ 3. Use lazy initialization for expensive objects","UnifiedDI.register(ExpensiveService.self) {","    \/\/ Only created when first requested","    ExpensiveService()","}","","\/\/ 4. Enable performance tracking in development","#if DEBUG","let metrics = UnifiedDI.getPerformanceMetrics()","print(\"DI Performance: \\(metrics.summary)\")","#endif"]},{"type":"heading","level":3,"text":"Memory Management","anchor":"Memory-Management"},{"syntax":"swift","type":"codeListing","code":["\/\/ Avoid retain cycles with weak references","class ServiceA {","    @Inject weak var serviceB: ServiceB? \/\/ Weak to break cycles","}","","\/\/ Release dependencies when no longer needed","UnifiedDI.release(TemporaryService.self)","","\/\/ Periodic cleanup in long-running apps","Task {","    while true {","        try await Task.sleep(nanoseconds: 60_000_000_000) \/\/ 1 minute","        UnifiedDI.performMemoryCleanup()","    }","}"]},{"type":"heading","level":2,"text":"Best Practices","anchor":"Best-Practices"},{"type":"heading","level":3,"text":"1. Consistent API Usage","anchor":"1-Consistent-API-Usage"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Choose one primary API and stick with it:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ ✅ Good: Consistent UnifiedDI usage","class AppDependencies {","    static func setup() {","        UnifiedDI.registerMany {","            Registration(A.self) { AImpl() }","            Registration(B.self) { BImpl() }","        }","    }","}","","\/\/ ❌ Bad: Mixing APIs","class MixedDependencies {","    static func setup() {","        UnifiedDI.register(A.self) { AImpl() }","        DI.register(B.self) { BImpl() }        \/\/ Different API","    }","}"]},{"type":"heading","level":3,"text":"2. Clear Dependency Interfaces","anchor":"2-Clear-Dependency-Interfaces"},{"syntax":"swift","type":"codeListing","code":["\/\/ ✅ Good: Clear protocol-based dependencies","protocol UserService {","    func fetchUser(id: String) async throws -> User","}","","class UserServiceImpl: UserService {","    @RequiredInject var apiClient: APIClient","","    func fetchUser(id: String) async throws -> User {","        return try await apiClient.fetchUser(id: id)","    }","}","","\/\/ Register interface, not implementation","UnifiedDI.register(UserService.self) { UserServiceImpl() }"]},{"type":"heading","level":3,"text":"3. Environment-Specific Configuration","anchor":"3-Environment-Specific-Configuration"},{"syntax":"swift","type":"codeListing","code":["enum DIEnvironment {","    static func configure() {","        #if DEBUG","        setupDevelopmentDependencies()","        #elseif STAGING","        setupStagingDependencies()","        #else","        setupProductionDependencies()","        #endif","    }","","    private static func setupDevelopmentDependencies() {","        UnifiedDI.registerMany {","            Registration(APIService.self) { MockAPIService() }","            Registration(Logger.self) { VerboseLogger() }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"This comprehensive API reference should help you effectively use DiContainer’s powerful dependency injection capabilities in your Swift applications.","type":"text"}]}]}],"sections":[],"variants":[{"paths":["\/documentation\/dicontainer\/coreapis"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/DiContainer\/documentation\/DiContainer\/CoreAPIs"},"abstract":[{"type":"text","text":"Complete reference for DiContainer’s core API components"}],"kind":"article","references":{"doc://DiContainer/documentation/DiContainer":{"type":"topic","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer","title":"DiContainer","abstract":[{"type":"text","text":"A modern, high-performance dependency injection framework designed for Swift Concurrency and Actor models."}],"kind":"symbol","url":"\/documentation\/dicontainer","role":"collection"}}}