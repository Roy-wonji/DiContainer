type":"heading","level":3,"anchor":"3%EB%8B%A8%EA%B3%84-%EC%9D%BC%EA%B4%84-%EB%93%B1%EB%A1%9D-%EC%8B%A4%ED%96%89"},{"syntax":"swift","code":["\/\/ 모든 모듈을 병렬로 등록","await container.build()"],"type":"codeListing"},{"text":"고급 사용 패턴","type":"heading","level":2,"anchor":"%EA%B3%A0%EA%B8%89-%EC%82%AC%EC%9A%A9-%ED%8C%A8%ED%84%B4"},{"text":"Factory 패턴과의 연동","type":"heading","level":3,"anchor":"Factory-%ED%8C%A8%ED%84%B4%EA%B3%BC%EC%9D%98-%EC%97%B0%EB%8F%99"},{"syntax":"swift","code":["let container = Container()","let repositoryFactory = RepositoryModuleFactory()","let useCaseFactory = UseCaseModuleFactory()","","\/\/ Factory에서 생성된 모듈들을 일괄 등록","await repositoryFactory.makeAllModules().asyncForEach { module in","    await container.register(module)","}","","await useCaseFactory.makeAllModules().asyncForEach { module in","    await container.register(module)","}","","\/\/ 모든 모듈을 병렬 등록","await container.build()"],"type":"codeListing"},{"text":"조건부 모듈 등록","type":"heading","level":3,"anchor":"%EC%A1%B0%EA%B1%B4%EB%B6%80-%EB%AA%A8%EB%93%88-%EB%93%B1%EB%A1%9D"},{"syntax":"swift","code":["let container = Container()","","\/\/ 환경에 따른 조건부 등록","if ProcessInfo.processInfo.environment[\"ENABLE_ANALYTICS\"] == \"true\" {","    container.register(analyticsModule)","}","","#if DEBUG","container.register(debugLoggingModule)","#else","container.register(productionLoggingModule)","#endif","","await container.build()"],"type":"codeListing"},{"text":"클로저를 활용한 구성","type":"heading","level":3,"anchor":"%ED%81%B4%EB%A1%9C%EC%A0%80%EB%A5%BC-%ED%99%9C%EC%9A%A9%ED%95%9C-%EA%B5%AC%EC%84%B1"},{"syntax":"swift","code":["let container = Container()","","container {","    \/\/ 클로저 내부에서 추가 설정","    print(\"모듈 등록 준비 완료\")","}",".register(module1)",".register(module2)","","await container.build()"],"type":"codeListing"},{"text":"성능 특징","type":"heading","level":2,"anchor":"%EC%84%B1%EB%8A%A5-%ED%8A%B9%EC%A7%95"},{"text":"병렬 처리 최적화","type":"heading","level":3,"anchor":"%EB%B3%91%EB%A0%AC-%EC%B2%98%EB%A6%AC-%EC%B5%9C%EC%A0%81%ED%99%94"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"동시 실행"}]},{"type":"text","text":": 독립적인 모듈들이 병렬로 등록되어 전체 시간 단축"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"메모리 효율","type":"text"}]},{"text":": 스냅샷 방식으로 불필요한 메모리 복사 최소화","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"CPU 활용"}]},{"type":"text","text":": 멀티코어 환경에서 모든 코어 활용 가능"}],"type":"paragraph"}]}]},{"text":"메모리 관리","type":"heading","level":3,"anchor":"%EB%A9%94%EB%AA%A8%EB%A6%AC-%EA%B4%80%EB%A6%AC"},{"syntax":"swift","code":["\/\/ 등록 완료 후 내부 모듈 배열은 자동으로 해제됨","await container.build() \/\/ 이후 modules 배열은 비워짐"],"type":"codeListing"},{"text":"동시성 모델","type":"heading","level":2,"anchor":"%EB%8F%99%EC%8B%9C%EC%84%B1-%EB%AA%A8%EB%8D%B8"},{"text":"Actor 기반 안전성","type":"heading","level":3,"anchor":"Actor-%EA%B8%B0%EB%B0%98-%EC%95%88%EC%A0%84%EC%84%B1"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"내부 상태 변경은 actor의 직렬 실행 큐에서만 발생","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"외부에서의 동시 접근이 자동으로 동기화됨"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"데이터 경쟁 조건 완전 차단"}]}]}]},{"anchor":"Task-Group-%ED%99%9C%EC%9A%A9","level":3,"type":"heading","text":"Task Group 활용"},{"code":["\/\/ 내부 구현 예시 (실제 코드)","await withTaskGroup(of: Void.self) { group in","    for module in modules {","        group.addTask { @Sendable in","            await module.register() \/\/ 각 모듈이 병렬 등록","        }","    }","    await group.waitForAll() \/\/ 모든 등록 완료까지 대기","}"],"type":"codeListing","syntax":"swift"},{"anchor":"%EC%A0%9C%ED%95%9C%EC%82%AC%ED%95%AD-%EB%B0%8F-%EA%B3%A0%EB%A0%A4%EC%82%AC%ED%95%AD","level":2,"type":"heading","text":"제한사항 및 고려사항"},{"anchor":"%E2%9A%A0%EF%B8%8F-%EC%9D%98%EC%A1%B4%EC%84%B1-%EC%88%9C%EC%84%9C","level":3,"type":"heading","text":"⚠️ 의존성 순서"},{"type":"paragraph","inlineContent":[{"text":"이 컨테이너는 의존성 간의 순서를 보장하지 않습니다. 순서가 중요한 경우:","type":"text"}]},{"code":["\/\/ ❌ 문제 상황: B가 A에 의존하지만 순서 보장 없음","container.register(moduleB) \/\/ A가 필요하지만 아직 등록되지 않을 수 있음","container.register(moduleA)","","\/\/ ✅ 해결책 1: 모듈 팩토리에서 의존성 해결","let moduleB = registerModule.makeDependency(BProtocol.self) {","    let a = DependencyContainer.live.resolve(AProtocol.self)!","    return BImplementation(dependency: a)","}","","\/\/ ✅ 해결책 2: 별도의 순서 보장 로직 사용","await container.register(moduleA).build() \/\/ A 먼저 등록","await Container().register(moduleB).build() \/\/ B 나중에 등록"],"type":"codeListing","syntax":"swift"},{"anchor":"%E2%9A%A0%EF%B8%8F-%EC%98%A4%EB%A5%98-%EC%B2%98%EB%A6%AC","level":3,"type":"heading","text":"⚠️ 오류 처리"},{"type":"paragraph","inlineContent":[{"text":"현재 구현에서는 모듈 등록 실패를 개별적으로 처리하지 않습니다:","type":"text"}]},{"code":["\/\/ 현재: 모든 모듈이 성공하거나 일부 실패해도 계속 진행","await container.build() \/\/ throws 하지 않음","","\/\/ 향후 확장 가능: 오류 수집 및 보고","\/\/ let failures = try await container.buildWithErrorHandling()"],"type":"codeListing","syntax":"swift"},{"anchor":"%EA%B4%80%EB%A0%A8-API","level":2,"type":"heading","text":"관련 API"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/Module"},{"text":": 개별 의존성 등록 단위","type":"text"}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/RegisterModule","type":"reference","isActive":true},{"type":"text","text":": 모듈 생성 헬퍼"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/DiContainer\/documentation\/DiContainer\/DependencyContainer"},{"type":"text","text":": 실제 의존성 저장소"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"%EC%82%AC%EC%9A%A9-%EC%98%88%EC%8B%9C","level":1,"type":"heading","text":"사용 예시"},{"code":["\/\/ 모듈 팩토리에서 [Module]